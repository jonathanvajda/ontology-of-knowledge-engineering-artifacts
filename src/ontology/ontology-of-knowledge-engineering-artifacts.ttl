               skos:example "Protege, TopBraid Composer"@en ;
               skos:scopeNote "A desktop or web application used by knowledge engineers to design, build, and test ontologies."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000085
okea:ont000085 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000958 ;
               dcterms:bibliographicCitation "https://robot.obolibrary.org/report"^^xsd:anyURI ;
               rdfs:label "ROBOT is an OBO Tool Measurement Output"@en ;
               skos:altLabel "Ontology Metric Output"@en ,
                             "ROBOT Measurement"@en ;
               skos:definition "An Information Content Entity that is generated by a ROBOT measurement or report process and represents measured properties, warnings, or errors of an ontology artifact."@en ;
               skos:example "A report output tracking the precise count of axioms generated by ROBOT"@en ;
               skos:scopeNote "A metrics report generated by the ROBOT tool to evaluate size, structure, and changes in an ontology file."@en ;
               cco2:ont00001753 "ROBOT output"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000086
okea:ont000086 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000030 ;
               dcterms:bibliographicCitation "https://robot.obolibrary.org/template"^^xsd:anyURI ;
               rdfs:label "ROBOT is an OBO Tool Template"@en ;
