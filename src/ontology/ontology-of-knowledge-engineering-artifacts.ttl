               skos:example "The combination of ontologies and SHACL shapes defining a corporate database layout"@en ;
               skos:scopeNote "The collective structural definitions (ontologies, rules, shapes) governing the valid architecture of a knowledge graph."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000125
okea:ont000125 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000958 ;
               rdfs:label "Reference Architecture"@en ;
               skos:altLabel "Enterprise Semantic Blueprint"@en ;
               skos:definition "An Information Content Entity that represents a reusable architecture for arranging systems, artifacts, roles, processes, and interfaces in a class of deployments."@en ;
               skos:example "A corporate blueprint document detailing Triple Store setup and ingestion pipelines"@en ;
               skos:scopeNote "A standard systems architecture blueprint defining how graph stores, ETL mappings, and validation layers interact."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000126
okea:ont000126 rdf:type owl:Class ;
               rdfs:subClassOf cceo:ComputerProgramExecution ;
               rdfs:label "Act of Import Closure"@en ;
               skos:altLabel "Import Closure Process"@en ;
               skos:definition "A Computer Program Execution that identifies, retrieves, and includes ontology modules designated by import declarations for use with a target ontology module."@en ;
               skos:example "`owl:imports <http://schema.org/>`"@en ;
               skos:scopeNote "A planned act that is prescribed by an ontology header directive, to dynamically fetch and include a separate external ontology."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000127
okea:ont000127 rdf:type owl:Class ;
               rdfs:subClassOf cceo:ComputerProgramExecution ;
               dcterms:bibliographicCitation "https://robot.obolibrary.org/validate-profile"^^xsd:anyURI ;
               rdfs:label "Act of Ontology Profile Validating"@en ;
               skos:altLabel "Profile Validation"@en ,
                             "ROBOT Validate Profile Command"@en ,
                             "Validate Profile"@en ;
               skos:definition "A Computer Program Execution that evaluates whether an ontology conforms to a specified Web Ontology Language Profile."@en ;
               skos:example "Running `robot validate-profile --profile EL --input merged.owl --output results/merged-validation.txt` to validate an ontology against the Web Ontology Language 2 Extended Linear Profile."@en ;
               skos:scopeNote "This process is tool-neutral; ROBOT is a common implementation. The profile argument is prescribed by a Web Ontology Language Profile individual, such as the Web Ontology Language 2 Extended Linear Profile."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000128
okea:ont000128 rdf:type owl:Class ;
               rdfs:subClassOf cceo:ComputerProgramExecution ;
               dcterms:bibliographicCitation "https://robot.obolibrary.org/materialize"^^xsd:anyURI ;
               rdfs:label "Act of Ontology Materializing"@en ;
               skos:altLabel "Act of Inferred Superclass Expression Materializing"@en ,
                             "Materialize"@en ,
                             "ROBOT Materialize Command"@en ;
               skos:definition "A Computer Program Execution that asserts inferred superclass axioms or superclass expression axioms into an ontology."@en ;
               skos:example "Running `robot materialize --reasoner ELK --input emr_example.obo --term BFO:0000050 --output results/emr_output.obo` to assert inferred superclass expressions."@en ;
               skos:scopeNote "This is distinct from Act of Ontology Realization, which computes the most specific classes to which individuals belong. ROBOT uses the commonplace command name 'materialize', so that wording is retained as an alternative label."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000129
okea:ont000129 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00001158 ;
               dcterms:bibliographicCitation "https://robot.obolibrary.org/merge"^^xsd:anyURI ;
               rdfs:label "Act of Ontology Merging"@en ;
               skos:altLabel "Merge"@en ,
                             "ROBOT Merge Command"@en ;
               skos:definition "An Act of Data Transformation that has as input two or more ontology modules or an ontology module with its import closure and has as output a single ontology module that includes axioms from the inputs according to a merge specification."@en ;
               skos:example "Running `robot merge --input edit.owl --input edit2.owl --output results/merged2.owl` to produce a merged ontology module."@en ;
               skos:scopeNote "This process concerns producing a merged ontology module or release product; it should not be confused with asserting that the input ontology modules are identical or interchangeable."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000130
okea:ont000130 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00001158 ;
               dcterms:bibliographicCitation "https://robot.obolibrary.org/rename"^^xsd:anyURI ;
               rdfs:label "Act of Ontology Internationalized Resource Identifier Renaming"@en ;
               skos:altLabel "Act of Ontology IRI Renaming"@en ,
                             "ROBOT Rename Command"@en ,
                             "Rename"@en ;
               skos:definition "An Act of Data Transformation that replaces one or more Internationalized Resource Identifiers used by ontology entities while preserving the intended semantic content of the ontology as far as specified by a renaming map or renaming rule."@en ;
               skos:example "Using a command-line ontology tool to replace a set of obsolete class IRIs with new class IRIs throughout an ontology module."@en ;
               skos:scopeNote "This process changes entity identifiers in bulk and is distinct from adding, removing, or changing human-readable labels."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000131
okea:ont000131 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000033 ;
