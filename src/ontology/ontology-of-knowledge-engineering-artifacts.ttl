               rdfs:subClassOf cco2:ont00000958 ;
               rdfs:label "Ontology Design Pattern"@en ;
               skos:altLabel "ODP"@en ,
                             "Semantic Pattern"@en ;
               skos:definition "An Information Content Entity that represents a reusable modeling solution designed to address a recurrent ontology design problem."@en ;
               skos:example "The Agent-Role structural design pattern"@en ;
               skos:scopeNote "A reusable, highly optimized structural template model designed to solve recurrent conceptual design problems in ontologies."@en ;
               cco2:ont00001753 "ODP"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000093
okea:ont000093 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000958 ;
               rdfs:label "Terminology Glossary"@en ;
               skos:altLabel "Glossary of Terms"@en ,
                             "Vocabulary Manifest"@en ;
               skos:definition "An Information Content Entity that catalogs terms and natural-language meanings for a domain or community and is designed to support later semantic modeling, communication, or governance."@en ;
               skos:example "A shared spreadsheet listing company terms and business definitions"@en ;
               skos:scopeNote "A non-technical reference document cataloging domain terminology before formalizing them into ontology classes."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000094
