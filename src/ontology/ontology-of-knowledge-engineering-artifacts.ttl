###  https://github.com/jonathanvajda/okea/ont000121
okea:ont000121 rdf:type owl:Class ;
               rdfs:subClassOf obo:IAO_8000000 ;
               rdfs:label "Core Ontology"@en ;
               skos:altLabel "Core Domain Model"@en ;
               skos:definition "An ontology module that represents concepts and relations common across a broad domain and is designed to support extension by more specialized domain or application ontologies."@en ;
               skos:example "An enterprise-wide ontology defining general concepts like `Asset` or `Contract`"@en ;
               skos:scopeNote "An intermediate ontology defining standard concepts across a broad domain, serving as a blueprint for specific sub-domains."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000122
okea:ont000122 rdf:type owl:Class ;
               rdfs:subClassOf obo:IAO_8000000 ;
               rdfs:label "Domain Ontology"@en ;
               skos:altLabel "Domain-Specific Model"@en ;
               skos:definition "An ontology module that represents entities and relations characteristic of a specified subject-matter domain."@en ;
               skos:example "GeoNames Ontology"@en ;
               skos:scopeNote "An ontology capturing the precise vocabulary, entities, and relationships unique to a specific industry or discipline."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000123
okea:ont000123 rdf:type owl:Class ;
               rdfs:subClassOf obo:IAO_8000000 ;
               rdfs:label "Application Ontology"@en ;
               skos:altLabel "App-Specific Model"@en ;
               skos:definition "An ontology module that represents entities and relations selected or constrained for use by a specified application or operational context."@en ;
               skos:example "An ontology engineered tailored specifically to drive a localized mobile dashboard UI"@en ;
               skos:scopeNote "A specialized, highly scoped ontology containing exact structural configurations required to power a specific application interface."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


