@prefix : <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix cceo: <http://www.ontologyrepository.com/CommonCoreOntologies/> .
@prefix cco2: <https://www.commoncoreontologies.org/> .
@prefix okea: <https://github.com/jonathanvajda/okea/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .

<https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> rdf:type owl:Ontology ;
                                                                                 owl:versionIRI <https://github.com/jonathanvajda/okea/2026-06-19/OntologyOfKnowledgeEngineeringArtifacts> ;
                                                                                 owl:imports obo:obo-slim ,
                                                                                             <http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CognitiveProcessOntology> ,
                                                                                             cco2:AgentOntology ,
                                                                                             cco2:ArtifactOntology ,
                                                                                             cco2:EventOntology ,
                                                                                             cco2:ExtendedRelationOntology ,
                                                                                             cco2:InformationEntityOntology ;
                                                                                 dcterms:creator "Jonathan Vajda"@en ;
                                                                                 dcterms:description "The Ontology of Knowledge Engineering Artifacts is a reference ontology that extends the Information Entity Ontology (in CCO) to represent various information artifacts that surround the use of linked data and ontologies."@en ;
                                                                                 rdfs:label "Ontology of Knowledge Engineering Artifacts"@en ;
                                                                                 owl:versionInfo "2026-06-19"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/bibliographicCitation
dcterms:bibliographicCitation rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/identifier
dcterms:identifier rdf:type owl:AnnotationProperty .


###  https://github.com/jonathanvajda/okea/has_data_description_text_value
okea:has_data_description_text_value rdf:type owl:AnnotationProperty ;
                                     rdfs:label "has data description"@en ;
                                     cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> ;
                                     rdfs:subPropertyOf dcterms:description ;
                                     rdfs:range xsd:string .


###  https://github.com/jonathanvajda/okea/has_standardized_datafield_identifier
okea:has_standardized_datafield_identifier rdf:type owl:AnnotationProperty ;
                                           rdfs:label "has standardized datafield identifier"@en ;
                                           skos:definition "An identifier of a datafield, whose code identifier is standardized or normalized procedurally or according to some schema."@en ;
                                           skos:example "NIEM uses an ID with a namespace prefix and then a human-readable identifier. E.g., 'nc:OrganizationType' to identify the data type that is about a 'body of people organized for a particular purpose.'"@en ;
                                           skos:scopeNote "As a matter of data architecture, data for entities are given unique identifiers that can be used univocally or analogously in different data tables or databases. The tokenization of the identifier is what is in view."@en ;
                                           cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> ;
                                           rdfs:subPropertyOf dcterms:identifier ;
                                           rdfs:range xsd:string .


###  https://github.com/jonathanvajda/okea/representation_conforms_to_specification
okea:representation_conforms_to_specification rdf:type owl:AnnotationProperty ;
                                              rdfs:label "representation conforms to specification"@en ;
                                              skos:definition "x representation conforms to specification y iff x is a representation, y is a specification (directive information content entity), and y specifies x, and x exemplifies the specification y."@en ;
                                              cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


#################################################################
#    Object Properties
#################################################################

###  https://github.com/jonathanvajda/okea/ont000010
okea:ont000010 rdf:type owl:ObjectProperty ;
               owl:inverseOf okea:ont000011 ;
               rdfs:domain okea:ont000002 ;
               rdfs:range cco2:ont00000958 ;
               rdfs:label "has competency question"@en ;
               skos:definition "x has competency question y iff x is some information content entity, y is a competency question, and y is intended to be used to evaluate coverage of entities (or relations) for some portion of reality that x represents."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000011
okea:ont000011 rdf:type owl:ObjectProperty ;
               rdfs:domain cco2:ont00000958 ;
               rdfs:range okea:ont000002 ;
               rdfs:label "is competency question of"@en ;
               skos:definition "x is competency question of y iff y is some information content entity, x is a competency question, and x is intended to be used to evaluate coverage of entities (or relations) for some portion of reality that y represents."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000012
okea:ont000012 rdf:type owl:ObjectProperty ;
               owl:inverseOf okea:ont000013 ;
               rdfs:domain cco2:ont00000958 ;
               rdfs:range okea:ont000004 ;
               rdfs:label "has mermaid diagram"@en ;
               skos:definition "x has mermaid diagram y iff x is some information content entity, y is a mermaid diagram (content entity), and y is intended to be used to represent visually some entity (or relations) for some portion of reality that x represents."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000013
okea:ont000013 rdf:type owl:ObjectProperty ;
               rdfs:domain okea:ont000004 ;
               rdfs:range cco2:ont00000958 ;
               rdfs:label "is mermaid diagram of"@en ;
               skos:definition "x is mermaid diagram of y iff y is some information content entity, x is a mermaid diagram (content entity), and x is intended to be used to represent visually some entity (or relations) for some portion of reality that y represents."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000014
okea:ont000014 rdf:type owl:ObjectProperty ;
               rdfs:domain cco2:ont00000958 ;
               rdfs:range cco2:ont00000958 ;
               rdfs:label "has formalization"@en ;
               skos:definition "x has formalization y iff x is an information content entity, y is an expression in formal language, such that the formal expression logically encodes the conditions defined by the information content entity."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000015
okea:ont000015 rdf:type owl:ObjectProperty ;
               rdfs:domain cco2:ont00000958 ;
               rdfs:range cco2:ont00000958 ;
               rdfs:label "is formalization of"@en ;
               skos:definition "x is formalization of y iff y has formalization x"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000026
okea:ont000026 rdf:type owl:ObjectProperty ;
               rdfs:domain cco2:ont00000965 ;
               rdfs:range obo:OBI_0001755 ;
               rdfs:label "has selection criterion"@en ;
               skos:definition "x has selection criterion y iff x is a directive information content entity (i.e., a standard or principle), y is a selection criterion, y delineates some necessary or sufficient condition z, and x is about z."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000027
okea:ont000027 rdf:type owl:ObjectProperty ;
               rdfs:domain obo:OBI_0001755 ;
               rdfs:range cco2:ont00000965 ;
               rdfs:label "is selection criterion of"@en ;
               skos:definition "x is selection criteria of y iff y has selection criterion x."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


#################################################################
#    Data properties
#################################################################

###  https://github.com/jonathanvajda/okea/has_competency_question_text_value
okea:has_competency_question_text_value rdf:type owl:DatatypeProperty ;
                                        rdfs:subPropertyOf cco2:ont00001765 ;
                                        rdfs:range xsd:string ;
                                        rdfs:label "has competency question text value"@en ;
                                        cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/has_git_repository_url
okea:has_git_repository_url rdf:type owl:DatatypeProperty ;
                            rdfs:range xsd:anyURI ;
                            rdfs:label "has git repository url"@en ;
                            skos:definition "x has git repository url y iff x is some entity and y is the uniform resource locator (URL) designating where code is under git versioning."@en ;
                            cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/has_mermaid_diagram_text_value
okea:has_mermaid_diagram_text_value rdf:type owl:DatatypeProperty ;
                                    rdfs:subPropertyOf cco2:ont00001765 ;
                                    rdfs:range xsd:string ;
                                    rdfs:label "has mermaid diagram text value"@en ;
                                    cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/has_query_text_value
okea:has_query_text_value rdf:type owl:DatatypeProperty ;
                          rdfs:subPropertyOf cco2:ont00001765 ;
                          rdfs:range xsd:string ;
                          rdfs:label "has query text value"@en ;
                          cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/has_sparql_query_text_value
okea:has_sparql_query_text_value rdf:type owl:DatatypeProperty ;
                                 rdfs:subPropertyOf okea:has_query_text_value ;
                                 rdfs:range xsd:string ;
                                 rdfs:label "has SPARQL Protocol and Resource Description Framework Query Language query text value"@en ;
                                 cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/has_sparql_update_text_value
okea:has_sparql_update_text_value rdf:type owl:DatatypeProperty ;
                                  rdfs:subPropertyOf okea:has_sparql_query_text_value ,
                                                     okea:has_update_query_text_value ;
                                  rdfs:range xsd:string ;
                                  rdfs:label "has SPARQL Protocol and Resource Description Framework Query Language update query text value"@en ;
                                  cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/has_sql_query_text_value
okea:has_sql_query_text_value rdf:type owl:DatatypeProperty ;
                              rdfs:subPropertyOf okea:has_query_text_value ;
                              rdfs:range xsd:string ;
                              rdfs:label "has Structured Query Language query text value"@en ;
                              cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/has_sql_update_text_value
okea:has_sql_update_text_value rdf:type owl:DatatypeProperty ;
                               rdfs:subPropertyOf okea:has_sql_query_text_value ,
                                                  okea:has_update_query_text_value ;
                               rdfs:range xsd:string ;
                               rdfs:label "has Structured Query Language update query text value"@en ;
                               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/has_update_query_text_value
okea:has_update_query_text_value rdf:type owl:DatatypeProperty ;
                                 rdfs:subPropertyOf okea:has_query_text_value ;
                                 rdfs:range xsd:string ;
                                 rdfs:label "has update query text value"@en ;
                                 cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


#################################################################
#    Classes
#################################################################

###  http://purl.obolibrary.org/obo/OBI_0001755
obo:OBI_0001755 rdf:type owl:Class .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ActOfRequestingInformation
cceo:ActOfRequestingInformation rdf:type owl:Class .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ApplicationSoftware
cceo:ApplicationSoftware rdf:type owl:Class .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ComputerProgram
cceo:ComputerProgram rdf:type owl:Class .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ComputerProgramExecution
cceo:ComputerProgramExecution rdf:type owl:Class .


###  http://www.ontologyrepository.com/CommonCoreOntologies/DatabaseSoftwareApplication
cceo:DatabaseSoftwareApplication rdf:type owl:Class .


###  http://www.ontologyrepository.com/CommonCoreOntologies/DigitalFileProcess
cceo:DigitalFileProcess rdf:type owl:Class .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ModelingProcess
cceo:ModelingProcess rdf:type owl:Class .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NetworkServer
cceo:NetworkServer rdf:type owl:Class .


###  http://www.ontologyrepository.com/CommonCoreOntologies/OntologyEditingSoftwareApplication
cceo:OntologyEditingSoftwareApplication rdf:type owl:Class .


###  http://www.ontologyrepository.com/CommonCoreOntologies/SoftwareStack
cceo:SoftwareStack rdf:type owl:Class .


###  https://github.com/jonathanvajda/okea/ont000001
okea:ont000001 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000958 ;
               dcterms:bibliographicCitation "Braun, D. (2022). Propositions and Questions. In Chris Tillman and Adam Murray (Eds), Routledge Handbook of Propositions."@en ,
                                             "https://doi.org/10.4324/9781315270500-34"^^xsd:anyURI ;
               rdfs:label "Interrogative Information Content Entity"@en ;
               skos:altLabel "Question"@en ;
               skos:definition "An Information Content Entity that is the object of some act of asking or wondering."@en ;
               skos:scopeNote "Strictly speaking, questions are the contents of interrogative sentences."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000002
okea:ont000002 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000001 ;
               dcterms:bibliographicCitation "Grüninger, M., Fox, M.S. (1995). The Role of Competency Questions in Enterprise Engineering. In: Rolstadås, A. (eds) Benchmarking — Theory and Practice. IFIP Advances in Information and Communication Technology. Springer, Boston, MA."@en ,
                                             "https://doi.org/10.1007/978-0-387-34847-6_3"^^xsd:anyURI ;
               rdfs:label "Competency Question Content Entity"@en ;
               skos:altLabel "CQ"@en ,
                             "Competency Question"@en ;
               skos:definition "An Interrogative Information Content Entity that is expressed in natural language, that is designed to assist in identifying what information is to be returned for some information system query (tell-and-ask service), with respect to whether a framework has coverage of the terms, relationships, and inferences to enable the query."@en ;
               skos:scopeNote "A competency question is typically used to provide a benchmark for what queries some information system is to handle and what vocabularies and taxonomies are relevant to answer the user's question."@en ;
               cco2:ont00001753 "CQ"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000003
okea:ont000003 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000001 ;
               dcterms:bibliographicCitation "The Department of Defense Architecture Framework (DoDAF), Version 2.0 (2009). Volume 1, 43-44."@en ,
                                             "https://dodcio.defense.gov/Portals/0/Documents/DODAF/DoDAF%20V2%20-%20Volume%201.pdf"^^xsd:anyURI ;
               rdfs:label "Decision Support Question Content Entity"@en ;
               skos:altLabel "DSQ"@en ,
                             "Decision Support Question"@en ;
               skos:definition "An Interrogative Information Content Entity that is expressed in natural language, that is designed to assist in identifying critical information requirements (CIRs) for making decisions regarding mission essential tasks (METs)."@en ;
               skos:scopeNote "A decision support question may involve one or many competency questions, which, when considered as a collection, are relevant for enabling a decision-maker to perform their METs."@en ;
               cco2:ont00001753 "DSQ"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000004
okea:ont000004 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000958 ;
               dcterms:bibliographicCitation "https://en.wikipedia.org/w/index.php?title=Mermaid&oldid=1341883926"^^xsd:anyURI ;
               rdfs:label "Mermaid Diagram"@en ;
               skos:definition "An Information Content Entity that represents some portion of reality visually, whose syntactic rules for generating an image is prescribed by the Mermaid syntax specification."@en ;
               skos:example "Mermaid syntax: ```graph TD; A[Agent<br>Activity ID: 123.12.001<br>System] --input in--> B{Is the system available:<br>Yes or No?}```"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000005
okea:ont000005 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000016 ;
               rdfs:label "Structured Query Language Query"@en ;
               skos:altLabel "SQL Query"@en ;
               skos:definition "A Database Query that is expressed in the syntax prescribed by the Structured Query Language specifications."@en ;
               cco2:ont00001753 "SQL Query"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000006
okea:ont000006 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000005 ;
               rdfs:label "Structured Query Language Update Query"@en ;
               skos:altLabel "SQL Update Query"@en ;
               skos:definition "A SQL Query that is designed to request a change in data assertions stored by an information system."@en ;
               cco2:ont00001753 "SQL Update"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000007
okea:ont000007 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000016 ;
               rdfs:label "SPARQL Protocol and Resource Description Framework Query Language Query"@en ;
               skos:altLabel "SPARQL Query"@en ;
               skos:definition "A Database Query that is expressed in the syntax prescribed by the SPARQL Protocol and RDF Query Language specifications."@en ;
               cco2:ont00001753 "SPARQL Query"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000008
okea:ont000008 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000007 ;
               rdfs:label "SPARQL Protocol and Resource Description Framework Query Language Update Query"@en ;
               skos:altLabel "SPARQL Update"@en ,
                             "SPARQL Update Query"@en ;
               skos:definition "A SPARQL Protocol and RDF Query Language Query that is designed to request a change in data assertions stored by an information system."@en ;
               cco2:ont00001753 "SPARQL Update"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000009
okea:ont000009 rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:unionOf ( cco2:ont00000127
                                                   cco2:ont00000653
                                                 )
                                   ] ;
               rdfs:subClassOf cco2:ont00000965 ;
               rdfs:label "Business Rule"@en ;
               skos:altLabel "Decision Logic" ;
               skos:definition "A Directive Information Content Entity that is designed to direct planned processes performed by an organization and is either an Algorithm or a Performance Specification."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000016
okea:ont000016 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000001 ;
               rdfs:label "Database Query"@en ;
               skos:definition "An Interrogative Information Content Entity that is expressed in the syntax prescribed by some query language specification."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000018
okea:ont000018 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000398 ;
               rdfs:label "W3C standard"@en ;
               skos:definition "A Reference System that is about a set of technical standards for the World Wide Web (W3C)."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000022
okea:ont000022 rdf:type owl:Class ;
               rdfs:subClassOf obo:IAO_8000000 ;
               rdfs:label "National Security Ontology Foundry ontology"@en ;
               skos:definition "An ontology module that is specified by the standards of the National Security Ontology Foundry community."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000023
okea:ont000023 rdf:type owl:Class ;
               rdfs:subClassOf cceo:ActOfRequestingInformation ;
               rdfs:label "Act of Information System Querying"@en ;
               skos:definition "An Act of Requesting Information that prescribes some information to perform some finding and delivering of information by means of a formal query."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000024
okea:ont000024 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000958 ;
               rdfs:label "Information System Query Result"@en ;
               skos:definition "An Information Content Entity that is found or delivered (or the lack thereof) according to an Act of Information System Querying."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000025
okea:ont000025 rdf:type owl:Class ;
               rdfs:subClassOf obo:IAO_0000300 ;
               rdfs:label "recommendation textual entity"@en ;
               skos:definition "A textual entity that expresses the recommendations to use a resource, e.g. software."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000028
okea:ont000028 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000366 ;
               rdfs:label "Knowledge Engineering Process"@en ;
               skos:definition "An Act of Information Processing that has as output, input, or specified objective some artifact used to develop, maintain, validate, publish, query, or operate an ontology, knowledge graph, semantic data layer, or related formal knowledge representation."@en ;
               skos:scopeNote "The update note asks to represent planned processes as distinct from plans, directives, syntaxes, specifications, files, and outputs used in knowledge engineering."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000029
okea:ont000029 rdf:type owl:Class ;
               rdfs:subClassOf cceo:ComputerProgram ;
               rdfs:label "Knowledge Engineering Computer Program"@en ;
               skos:altLabel "Knowledge Engineering Software Artifact"@en ;
               skos:definition "A Computer Program that is designed to participate in developing, transforming, validating, querying, reasoning over, visualizing, or operating semantic information resources."@en ;
               skos:example "Apache Jena RDF Writer"@en ;
               skos:scopeNote "The table includes serializers, reasoners, ontology editors, terminology server components, semantic middleware, and visualizers as software or software components."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000030
okea:ont000030 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000965 ;
               rdfs:label "Knowledge Engineering Specification"@en ;
               skos:definition "A Directive Information Content Entity that prescribes syntactic, semantic, architectural, operational, or procedural constraints for some knowledge engineering artifact or process."@en ;
               skos:scopeNote "This class is a parent for profiles, protocols, schemas, mappings, templates, configurations, and architecture specifications that direct knowledge engineering activity."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000031
okea:ont000031 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000958 ;
               rdfs:label "Semantic Web File"@en ;
               skos:definition "An Information Content Entity that is concretized as a digital file and is designed to bear content used in representing, constraining, querying, transforming, documenting, validating, or publishing Semantic Web resources."@en ;
               skos:scopeNote "A file class is used where the artifact is distinguished by being serialized into a digital file, not merely by the content it bears."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000032
okea:ont000032 rdf:type owl:Class ;
               rdfs:subClassOf obo:IAO_8000000 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/owl2-syntax/"^^xsd:anyURI ;
               rdfs:label "Serialized Ontology Module"@en ;
               skos:altLabel "Ontology File"@en ,
                             "Ontology Serialized"@en ;
               skos:definition "An ontology module that is concretized in a digital file according to an ontology serialization syntax specification."@en ;
               skos:example "This .ttl file of the Informed Consent Ontology"@en ;
               skos:scopeNote "A formal, explicit specification of a shared conceptualization containing classes, properties, and axioms, serialized into a web ontology language format."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000033
okea:ont000033 rdf:type owl:Class ;
               rdfs:subClassOf cceo:DigitalFileProcess ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/turtle/"^^xsd:anyURI ;
               rdfs:label "Graph Serialization Process"@en ;
               skos:altLabel "Act of Serializing a Graph"@en ,
                             "Graph Dumping"@en ,
                             "Marshalling"@en ,
                             "Serialization Process"@en ;
               skos:definition "A Digital File Process that has as output a linear digital representation of an in-memory graph or graph-like information structure according to a serialization syntax specification."@en ;
               skos:example "Exporting a graph to a `.ttl` file"@en ;
               skos:scopeNote "The technical operation of parsing an in-memory graph structure into a linear stream of characters/bytes."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000034
okea:ont000034 rdf:type owl:Class ;
               rdfs:subClassOf cceo:ApplicationSoftware ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/rdf11-concepts/"^^xsd:anyURI ;
               rdfs:label "Graph Serializer"@en ;
               skos:altLabel "Graph Exporter"@en ,
                             "Parser-Writer"@en ,
                             "Serializer"@en ;
               skos:definition "An Application Software that is designed to create a serialized representation of a graph or graph-like information structure."@en ;
               skos:example "Apache Jena RDF Writer"@en ;
               skos:scopeNote "The software component or module responsible for turning an active programmatic graph model into written text files."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000035
okea:ont000035 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000030 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/owl2-profiles/"^^xsd:anyURI ;
               rdfs:label "Web Ontology Language Profile"@en ;
               skos:altLabel "OWL Profile"@en ;
               skos:definition "A Knowledge Engineering Specification that prescribes a subset of Web Ontology Language constructs and semantic conditions for a class of ontology documents or reasoning services."@en ;
               cco2:ont00001753 "OWL profile"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000040
okea:ont000040 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000965 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/shacl/"^^xsd:anyURI ;
               rdfs:label "Graph Constraint"@en ;
               skos:altLabel "Validation Rule"@en ;
               skos:definition "A Directive Information Content Entity that prescribes a condition that members or parts of a graph are intended to satisfy."@en ;
               skos:example "An expression enforcing that every device has an active IP address"@en ;
               skos:scopeNote "A logical rule applied over an RDF graph to preserve data integrity and catch bad data patterns."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000041
okea:ont000041 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000040 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/shacl/"^^xsd:anyURI ;
               rdfs:label "Shapes Constraint Language Constraint"@en ;
               skos:altLabel "SHACL Constraint"@en ;
               skos:definition "A Graph Constraint that is expressed according to the Shapes Constraint Language and is designed to constrain members or parts of an RDF graph."@en ;
               skos:example "W3C SHACL"@en ;
               skos:scopeNote "A logical rule designed to validate whether RDF graph conforms to some structure or shape."@en ;
               cco2:ont00001753 "SHACL"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000042
okea:ont000042 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000031 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/shacl/"^^xsd:anyURI ;
               rdfs:label "Shapes Constraint Language Shape File"@en ;
               skos:altLabel "Constraint Document"@en ,
                             "SHACL Shape File"@en ;
               skos:definition "A Semantic Web File that bears a collection of Shapes Constraint Language shapes or constraints for validating RDF graphs."@en ;
               skos:example "A `.shacl.ttl` file containing target system rules"@en ;
               skos:scopeNote "A file containing a collection of structural constraints written in SHACL format used to validate RDF datasets."@en ;
               cco2:ont00001753 "SHACL"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000043
okea:ont000043 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000958 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/shacl/"^^xsd:anyURI ;
               rdfs:label "Validation Report"@en ;
               skos:altLabel "SHACL Validation Report"@en ;
               skos:definition "An Information Content Entity that is generated by a validation process and represents whether and how a validated information resource satisfies one or more validation constraints."@en ;
               skos:example "An RDF graph output detailing graph structural compliance errors"@en ;
               skos:scopeNote "The comprehensive output graph generated by a validation engine detailing whether a dataset passed or failed data rules."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000044
okea:ont000044 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000958 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/shacl/"^^xsd:anyURI ;
               rdfs:label "Validation Result"@en ;
               skos:altLabel "Error Entry"@en ;
               skos:definition "An Information Content Entity that is a component of a validation report and represents the satisfaction or violation of a validation constraint by a specified focus node, value node, or graph component."@en ;
               skos:example "A graph node identifying that `ex:Alice` is missing a required property"@en ;
               skos:scopeNote "A specific node structure in a validation report that details exactly which triple broke which structural rule."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000045
okea:ont000045 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000958 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/shacl/"^^xsd:anyURI ;
               rdfs:label "Validation Severity Level"@en ;
               skos:altLabel "SHACL Severity"@en ,
                             "Severity Level"@en ;
               skos:definition "An Information Content Entity that categorizes the intended criticality of a validation result or validation constraint."@en ;
               skos:example "`sh:Violation`, `sh:Warning`, `sh:Info`"@en ;
               skos:scopeNote "A categorization marker inside a validation shape declaring the criticality of a specific rule failure."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000046
okea:ont000046 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000031 ;
               dcterms:bibliographicCitation "https://shex.io/shex-semantics/"^^xsd:anyURI ;
               rdfs:label "Shape Expressions Schema"@en ;
               skos:altLabel "ShEx Schema"@en ,
                             "Shape Expression Document"@en ;
               skos:definition "A Semantic Web File that bears a schema expressed in the Shape Expressions language for specifying expected RDF graph structures."@en ;
               skos:example "A `.shex` schema file"@en ;
               skos:scopeNote "A clear, compact layout document mapping expected graph structures using Shape Expressions syntax."@en ;
               cco2:ont00001753 "ShEx"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000047
okea:ont000047 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000041 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/shacl/"^^xsd:anyURI ;
               rdfs:label "Node Shape"@en ;
               skos:altLabel "Entity Constraint"@en ;
               skos:definition "A Shapes Constraint Language Constraint that prescribes structural expectations for RDF nodes selected by one or more targets."@en ;
               skos:example "A shape targeting instances of `ex:User`"@en ;
               skos:scopeNote "A specific SHACL configuration block that defines structural expectations and validation targets for an entire RDF resource node."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000048
okea:ont000048 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000041 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/shacl/"^^xsd:anyURI ;
               rdfs:label "Property Shape"@en ;
               skos:altLabel "Attribute Constraint"@en ;
               skos:definition "A Shapes Constraint Language Constraint that prescribes value, datatype, cardinality, path, or related conditions for RDF properties of selected focus nodes."@en ;
               skos:example "A constraint ensuring `ex:hasEmail` contains a `@` character"@en ;
               skos:scopeNote "A specific SHACL block detailing exact structural, datatype, and multiplicity constraints for an explicit graph property."@en ;
               cco2:ont00001753 "SHACL"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000049
okea:ont000049 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000965 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/shacl/"^^xsd:anyURI ;
               rdfs:label "Shape Target Declaration"@en ;
               skos:altLabel "SHACL Target"@en ,
                             "Target Declaration"@en ;
               skos:definition "A Directive Information Content Entity that identifies the RDF nodes or graph components to which a shape is intended to apply."@en ;
               skos:example "`sh:targetClass ex:Customer`"@en ;
               skos:scopeNote "A directive inside a shape configuration identifying exactly which graph elements must be audited by a validation engine."@en ;
               cco2:ont00001753 "SHACL"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000050
okea:ont000050 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000965 ;
               dcterms:bibliographicCitation "https://www.w3.org/Submission/SWRL/"^^xsd:anyURI ;
               rdfs:label "Semantic Web Rule Language Rule"@en ;
               skos:altLabel "SWRL Rule"@en ;
               skos:definition "A Directive Information Content Entity that is expressed according to the Semantic Web Rule Language and prescribes an implication over ontology classes, properties, individuals, or built-ins."@en ;
               skos:example "`Person(?p) ^ hasAge(?p, ?a) ^ swrlb:greaterThan(?a, 18) -> Adult(?p)`"@en ;
               skos:scopeNote "A logical rule designed to execute inference operations by combining OWL axioms with Horn-clause logical notation."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000051
okea:ont000051 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000007 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/sparql11-query/"^^xsd:anyURI ;
               rdfs:label "SPARQL Protocol and Resource Description Framework Query Language Select Query"@en ;
               skos:altLabel "Data Retrieval Query"@en ,
                             "SELECT Query"@en ;
               skos:definition "A SPARQL Protocol and RDF Query Language Query that is designed to return tabular bindings for selected variables."@en ;
               skos:example "`SELECT ?name WHERE { ?s ex:name ?name }`"@en ;
               skos:scopeNote "A foundational SPARQL query type that outputs tabular variable matches in a structured column format."@en ;
               cco2:ont00001753 "SPARQL Select"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000052
okea:ont000052 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000007 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/sparql11-query/"^^xsd:anyURI ;
               rdfs:label "SPARQL Protocol and Resource Description Framework Query Language Construct Query"@en ;
               skos:altLabel "CONSTRUCT Query"@en ,
                             "Graph Generation Query"@en ;
               skos:definition "A SPARQL Protocol and RDF Query Language Query that is designed to return an RDF graph constructed from graph-template instantiations over matching solution bindings."@en ;
               skos:example "`CONSTRUCT { ?s a ex:Person } WHERE { ?s ex:hasSSN ?ssn }`"@en ;
               skos:scopeNote "A query variation that outputs a freshly minted, valid RDF graph based on matching variable configurations."@en ;
               cco2:ont00001753 "SPARQL Construct"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000053
okea:ont000053 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000007 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/sparql11-query/"^^xsd:anyURI ;
               rdfs:label "SPARQL Protocol and Resource Description Framework Query Language Ask Query"@en ;
               skos:altLabel "ASK Query"@en ,
                             "Boolean Check Query"@en ;
               skos:definition "A SPARQL Protocol and RDF Query Language Query that is designed to return a boolean value indicating whether a graph pattern has at least one solution."@en ;
               skos:example "`ASK WHERE { ?s a ex:Admin }`"@en ;
               skos:scopeNote "A query structure that returns a flat boolean value (`true` or `false`) based on whether the graph pattern matches data."@en ;
               cco2:ont00001753 "SPARQL Ask"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000054
okea:ont000054 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000007 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/sparql11-query/"^^xsd:anyURI ;
               rdfs:label "SPARQL Protocol and Resource Description Framework Query Language Describe Query"@en ;
               skos:altLabel "DESCRIBE Query"@en ,
                             "Resource Inspection Query"@en ;
               skos:definition "A SPARQL Protocol and RDF Query Language Query that is designed to return an implementation-dependent RDF graph describing specified resources or resources matching a graph pattern."@en ;
               skos:example "`DESCRIBE ex:Alice`"@en ;
               skos:scopeNote "A query operation returning an implementation-dependent RDF graph that represents all accessible metadata about a specific target resource."@en ;
               cco2:ont00001753 "SPARQL Describe"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000055
okea:ont000055 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000965 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/sparql11-query/"^^xsd:anyURI ;
               rdfs:label "SPARQL Protocol and Resource Description Framework Query Language Filter Expression"@en ;
               skos:altLabel "SPARQL Filter Expression"@en ,
                             "Conditional Filter"@en ,
                             "Filter Expression"@en ;
               skos:definition "A Directive Information Content Entity that is expressed in the SPARQL expression syntax and prescribes a condition for excluding solution mappings from a query result."@en ;
               skos:example "`FILTER (?age > 21)`"@en ;
               skos:scopeNote "A logical evaluation statement embedded inside a query to exclude solutions that fail specific evaluation benchmarks."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000056
okea:ont000056 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000965 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/sparql11-query/"^^xsd:anyURI ;
               rdfs:label "SPARQL Protocol and Resource Description Framework Query Language Triple Pattern"@en ;
               skos:altLabel "Single Constraint Matcher"@en ,
                             "Triple Pattern"@en ;
               skos:definition "A Directive Information Content Entity that is expressed in SPARQL syntax and prescribes a subject, predicate, and object matching pattern in which any position may be a variable."@en ;
               skos:example "`?person ex:livesIn ?city .`"@en ;
               skos:scopeNote "The primitive structural template unit of a SPARQL query, substituting variables into subject, predicate, or object slots."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000057
okea:ont000057 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000965 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/sparql11-query/"^^xsd:anyURI ;
               rdfs:label "SPARQL Protocol and Resource Description Framework Query Language Basic Graph Pattern"@en ;
               skos:altLabel "BGP"@en ,
                             "Basic Graph Pattern"@en ,
                             "Pattern Group"@en ;
               skos:definition "A Directive Information Content Entity that is expressed in SPARQL syntax and prescribes a set of triple patterns that must be matched together against an RDF graph."@en ;
               skos:example "A set of three consecutive triple patterns wrapped in braces"@en ;
               skos:scopeNote "A collection of combined triple patterns that must simultaneously evaluate successfully against a targeted data store."@en ;
               cco2:ont00001753 "BGP"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000058
okea:ont000058 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000965 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/sparql11-federated-query/"^^xsd:anyURI ;
               rdfs:label "SPARQL Protocol and Resource Description Framework Query Language Federated Query Service Pattern"@en ;
               skos:altLabel "Distributed SPARQL Query"@en ,
                             "Federated Query SERVICE"@en ;
               skos:definition "A Directive Information Content Entity that is expressed in SPARQL syntax and prescribes evaluation of part of a query by a remote SPARQL service."@en ;
               skos:example "`SERVICE <url> { ... }`"@en ;
               skos:scopeNote "A specialized SPARQL function enabling a local engine to query a completely distinct remote endpoint mid-execution."@en ;
               cco2:ont00001753 "SPARQL Service"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000059
okea:ont000059 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000030 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/sparql11-http-rdf-update/"^^xsd:anyURI ;
               rdfs:label "SPARQL Protocol and Resource Description Framework Query Language Graph Store Hypertext Transfer Protocol"@en ;
               skos:altLabel "Graph Store Protocol"@en ;
               skos:definition "A Knowledge Engineering Specification that prescribes HTTP operations for managing RDF graphs in a graph store without requiring explicit SPARQL update syntax."@en ;
               skos:example "Direct `PUT` / `POST` HTTP requests to a graph endpoint"@en ;
               skos:scopeNote "A W3C standard web protocol utilizing RESTful patterns to manage whole RDF graphs directly without explicit update syntax."@en ;
               cco2:ont00001753 "SPARQL HTTP"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000060
okea:ont000060 rdf:type owl:Class ;
               rdfs:subClassOf cceo:NetworkServer ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/sparql11-overview/"^^xsd:anyURI ;
               rdfs:label "SPARQL Protocol and Resource Description Framework Query Language Endpoint"@en ;
               skos:altLabel "Semantic API URL"@en ,
                             "SPARQL Endpoint"@en ;
               skos:definition "A Network Server that provides a network-accessible service designed to receive SPARQL protocol requests and return query results or update responses."@en ;
               skos:example "https://dbpedia.org/sparql"^^xsd:anyURI ;
               skos:scopeNote "A publicly or privately accessible web service URL that receives and processes incoming SPARQL queries via HTTP protocol."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000061
okea:ont000061 rdf:type owl:Class ;
               rdfs:subClassOf cceo:DatabaseSoftwareApplication ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/rdf11-concepts/"^^xsd:anyURI ;
               rdfs:label "Triple Store"@en ;
               skos:altLabel "RDF Database"@en ;
               skos:definition "A Database Software Application that is designed to store, index, manage, and answer queries over RDF triples."@en ;
               skos:example "GraphDB, Blazegraph"@en ;
               skos:scopeNote "A dedicated graph database optimized for indexing, storing, and evaluating RDF triple statements."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000062
okea:ont000062 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000061 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/rdf11-concepts/"^^xsd:anyURI ;
               rdfs:label "Quad Store"@en ;
               skos:altLabel "Context-Aware RDF Database"@en ;
               skos:definition "A Triple Store that is designed to store, index, manage, and answer queries over RDF datasets containing graph names in addition to triple components."@en ;
               skos:example "Virtuoso, Stardog"@en ;
               skos:scopeNote "An enterprise graph database configured natively to manage multi-graph datasets by tracking the quad position."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000063
okea:ont000063 rdf:type owl:Class ;
               rdfs:subClassOf cceo:ApplicationSoftware ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/owl2-profiles/"^^xsd:anyURI ;
               rdfs:label "Ontology Reasoner"@en ;
               skos:altLabel "Inference Engine"@en ,
                             "Semantic Reasoner"@en ;
               skos:definition "An Application Software that is designed to compute logical consequences of ontology axioms, graph assertions, rules, or entailment regimes."@en ;
               skos:example "HermiT, Pellet, Openllet"@en ;
               skos:scopeNote "A software module used to evaluate ontology rules, compute sub-class hierarchies, check consistency, and infer unstated assertions."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000064
okea:ont000064 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000030 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/rdf11-mt/"^^xsd:anyURI ;
               rdfs:label "Entailment Regime"@en ;
               skos:altLabel "Reasoning Profile"@en ;
               skos:definition "A Knowledge Engineering Specification that prescribes which semantic entailment rules are to be applied when interpreting, querying, or validating an RDF graph or ontology."@en ;
               skos:example "RDFS Entailment, OWL 2 DL Entailment"@en ;
               skos:scopeNote "A formal configuration specification defining exactly which logic rules a database must execute during data parsing or query evaluations."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000065
okea:ont000065 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000958 ;
               rdfs:label "Materialized Triple Set"@en ;
               skos:altLabel "Cached Triples"@en ,
                             "Materialized Triples"@en ,
                             "Pre-computed Inferences"@en ;
               skos:definition "An Information Content Entity that consists of RDF triples asserted into storage as the output of an inference process."@en ;
               skos:example "Saving inferred properties directly into database storage"@en ;
               skos:scopeNote "The physical process or output artifacts of permanently saving calculated implicit triples directly to disk to boost query performance."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000066
okea:ont000066 rdf:type owl:Class ;
               rdfs:subClassOf cceo:ComputerProgramExecution ;
               rdfs:label "Dynamic Inference Process"@en ;
               skos:altLabel "On-the-fly Reasoning"@en ;
               skos:definition "A Computer Program Execution that computes logical consequences during query answering, validation, or application execution without first storing all inferred assertions as materialized triples."@en ;
               skos:example "Evaluation of class inheritance during a runtime query"@en ;
               skos:scopeNote "The system approach of computing implicit triples dynamically on-the-fly exactly when an application executes a query."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000067
okea:ont000067 rdf:type owl:Class ;
               rdfs:subClassOf cceo:ComputerProgramExecution ;
               rdfs:label "Act of Ontology Consistency Checking"@en ;
               skos:altLabel "Consistency Check"@en ,
                             "Logical Sanity Check"@en ,
                             "Ontology Consistency Checking Process"@en ;
               skos:definition "A Computer Program Execution that evaluates whether a set of ontology axioms and assertions entails a contradiction."@en ;
               skos:example "Running a scan to confirm no instance belongs to two disjoint classes"@en ;
               skos:scopeNote "A reasoner task verifying that an active ontology configuration contains no contradictory logic statements."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000068
okea:ont000068 rdf:type owl:Class ;
               rdfs:subClassOf cceo:ComputerProgramExecution ;
               rdfs:label "Act of Ontology Classification"@en ;
               skos:altLabel "Classification"@en ,
                             "Hierarchy Computation"@en ,
                             "Ontology Classification Process"@en ;
               skos:definition "A Computer Program Execution that computes a class hierarchy entailed by ontology axioms and assertions."@en ;
               skos:example "Computing that `ex:SportsCar` is a nested subclass of `ex:Vehicle`"@en ;
               skos:scopeNote "The reasoner task of processing declared property parameters to build a fully articulated, verified taxonomy of classes."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000069
okea:ont000069 rdf:type owl:Class ;
               rdfs:subClassOf cceo:ComputerProgramExecution ;
               rdfs:label "Act of Ontology Realization"@en ;
               skos:altLabel "Instance Typing Inference"@en ,
                             "Ontology Realization Process"@en ,
                             "Realization"@en ;
               skos:definition "A Computer Program Execution that computes the most specific ontology classes to which specified individuals belong."@en ;
               skos:example "Determining an individual belongs to `ex:Parent` because they have a child"@en ;
               skos:scopeNote "The reasoner task of determining the most specific direct logical classes that an individual belongs to."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000070
okea:ont000070 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000958 ;
               rdfs:label "Ontology Quality Metric"@en ;
               skos:altLabel "Ontology Scorecard"@en ;
               skos:definition "An Information Content Entity that represents a measurement specification or measurement value designed to evaluate some quality of an ontology artifact."@en ;
               skos:example "Metric tracking overall cyclomatic complexity and missing labels"@en ;
               skos:scopeNote "A measurable benchmark evaluating structural attributes of an ontology file, such as depth, density, or readability."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000071
okea:ont000071 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000965 ;
               rdfs:label "Horn Clause"@en ;
               skos:altLabel "Logic Rule Component"@en ;
               skos:definition "A Directive Information Content Entity that is expressed as a logical clause containing at most one positive literal and is designed to prescribe an implication usable by a rule system."@en ;
               skos:example "`A and B implies C`"@en ;
               skos:scopeNote "A specific logical clause formula containing at most one positive literal, serving as the foundational building block of rule engines."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000072
okea:ont000072 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000965 ;
               rdfs:label "Datalog Rule"@en ;
               skos:altLabel "Declarative Logic Statement"@en ;
               skos:definition "A Directive Information Content Entity that is expressed in Datalog syntax and is designed to prescribe logical consequences over relational or graph-structured data."@en ;
               skos:example "`Grandparent(x, y) :- Parent(x, z), Parent(z, y)`"@en ;
               skos:scopeNote "A truly declarative logic language format used for executing complex recursive rules over structural tabular datasets."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000073
okea:ont000073 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000965 ;
               rdfs:label "Production Rule"@en ;
               skos:altLabel "Operational Rule"@en ;
               skos:definition "A Directive Information Content Entity that is expressed as a condition-action rule and is designed to prescribe an action when specified conditions are satisfied."@en ;
               skos:example "`IF pattern THEN action`"@en ;
               skos:scopeNote "An operational rule format used in business automation systems to execute specific code actions when graph patterns match."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000074
okea:ont000074 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000030 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/r2rml/"^^xsd:anyURI ;
               rdfs:label "Relational to Resource Description Framework Mapping Language Mapping"@en ;
               skos:altLabel "Database Template"@en ,
                             "R2RML Mapping"@en ;
               skos:definition "A Knowledge Engineering Specification that is expressed in the Relational to RDF Mapping Language and prescribes how rows in relational database tables are to be transformed into RDF triples."@en ;
               skos:example "A specific configuration document matching an `EMPLOYEE` table to `ex:Employee`"@en ;
               skos:scopeNote "A concrete, written script containing directives that tell an ETL pipeline how to convert relational database columns into triples."@en ;
               cco2:ont00001753 "R2RML"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000075
okea:ont000075 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000030 ;
               dcterms:bibliographicCitation "https://rml.io/specs/rml/"^^xsd:anyURI ;
               rdfs:label "Resource Description Framework Mapping Language Mapping"@en ;
               skos:altLabel "RDF Mapping Language"@en ,
                             "RML"@en ;
               skos:definition "A Knowledge Engineering Specification that is expressed in the RDF Mapping Language and prescribes how data from heterogeneous sources are to be transformed into RDF triples."@en ;
               skos:example "An `.rml` script mapping JSON/XML feeds"@en ;
               skos:scopeNote "An extended mapping language built as a superset of R2RML, designed to pull raw data from JSON, XML, CSV, and Web APIs into RDF graphs."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000076
okea:ont000076 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00001158 ;
               dcterms:bibliographicCitation "https://www.w3.org/TR/rdb-direct-mapping/"^^xsd:anyURI ;
               rdfs:label "Direct Relational to Resource Description Framework Mapping Process"@en ;
               skos:altLabel "Default Database Mapping"@en ,
                             "Direct Mapping"@en ;
               skos:definition "An Act of Data Transformation that transforms a relational database into RDF according to a default mapping from relational schema structures to RDF graph structures."@en ;
               skos:example "Automatically turning table names into classes and columns into properties"@en ;
               skos:scopeNote "A standardized baseline method for translating a relational database structure into RDF automatically based strictly on table schemas."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000077
okea:ont000077 rdf:type owl:Class ;
               rdfs:subClassOf cceo:ComputerProgramExecution ;
               rdfs:label "Act of Knowledge Graph Virtualizing"@en ;
               skos:altLabel "Knowledge Graph Virtualization Process"@en ,
                             "Ontology-Based Data Access"@en ,
                             "VKG"@en ,
                             "Virtual Knowledge Graph"@en ;
               skos:definition "A Computer Program Execution that answers graph queries over source data by using mappings while leaving the source data in its original storage systems."@en ;
               skos:example "Virtualization through the Ontop framework configuration"@en ;
               skos:scopeNote "An act of data retrieval wherein graph data is returned in real-time through mappings, while the original data remains in original relational stores."@en ;
               cco2:ont00001753 "OBDA"@en ,
                                "VKG"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000078
okea:ont000078 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000030 ;
               rdfs:label "Semantic Bridge"@en ;
               skos:altLabel "Data Transformation Map"@en ;
               skos:definition "A Knowledge Engineering Specification that prescribes transformations between representations governed by different ontologies, schemas, versions, or data shapes."@en ;
               skos:example "A pipeline script converting data from an old ontology format into a new industry standard format"@en ;
               skos:scopeNote "A mapping transformation asset designed to translate data between different ontology versions or shapes."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000079
okea:ont000079 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000030 ;
               rdfs:label "Semantic Downlift Configuration"@en ;
               skos:altLabel "Downlift Configuration"@en ,
                             "Semantic Flattening Script"@en ;
               skos:definition "A Knowledge Engineering Specification that prescribes how semantic graph content is to be transformed into a less semantically expressive representation for downstream systems."@en ;
               skos:example "Exporting a graph payload into a standard relational JSON structure"@en ;
               skos:scopeNote "A technical script that strips down and flattens complex semantic graph objects back into simple legacy files for consumer apps."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000080
okea:ont000080 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000030 ;
               rdfs:label "Semantic Uplift Configuration"@en ;
               skos:altLabel "Data Ingestion Map"@en ,
                             "Semantic Enrichment Script"@en ,
                             "Uplift Configuration"@en ;
               skos:definition "A Knowledge Engineering Specification that prescribes how less semantically explicit source data are to be transformed into ontology-governed graph content."@en ;
               skos:example "XML-to-RDF ingestion instruction set"@en ;
               skos:scopeNote "A configured automation asset map detailing how to convert legacy, non-semantic enterprise files up into an ontology layer."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000081
okea:ont000081 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000958 ;
               rdfs:label "Semantic Data Layer"@en ;
               skos:altLabel "Common Semantic Layer"@en ,
                             "Semantic Fabric"@en ,
                             "Virtual Semantic Fabric"@en ;
               skos:definition "An Information Content Entity that is designed to provide a unified semantic representation and access layer over one or more distributed data sources."@en ;
               skos:example "A unified semantic graph abstraction spanning across five corporate legacy data silos"@en ;
               skos:scopeNote "An abstract data access layer providing a clean, context-rich graph interface over distributed enterprise systems."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000082
okea:ont000082 rdf:type owl:Class ;
               rdfs:subClassOf cceo:ModelingProcess ;
               rdfs:label "Act of Data Silo Alignment"@en ;
               skos:altLabel "System Integration Mapping"@en ;
               skos:definition "A Modeling Process that identifies and records correspondences between data structures from isolated systems and a shared semantic model."@en ;
               skos:example "A crosswalk sheet connecting disparate application keys"@en ;
               skos:scopeNote "The process and resulting artifacts of mapping isolated, incompatible company systems to a unified ontology."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


