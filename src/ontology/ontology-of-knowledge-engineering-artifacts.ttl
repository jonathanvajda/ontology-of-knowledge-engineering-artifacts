               skos:example "`catalog-v001.xml` generated by Protege"@en ;
               skos:scopeNote "An XML tracking file used by editors to map remote ontology imports to local offline copies on a developer's machine."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


