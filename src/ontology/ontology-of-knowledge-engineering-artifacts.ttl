               skos:example "A CSV with columns headers like `ID`, `LABEL`, `SC %`"@en ;
               skos:scopeNote "A data-entry spreadsheet structured with specialized macro headers used to bulk-generate hundreds of ontology axioms automatically."@en ;
               cco2:ont00001753 "ROBOT template"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000087
okea:ont000087 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000030 ;
               rdfs:label "Ontorat Template"@en ;
               skos:altLabel "Automated Enrichment Layout"@en ;
               skos:definition "A Knowledge Engineering Specification that is expressed as a template for generating ontology axioms from spreadsheet-like source data."@en ;
               skos:example "A configuration sheet generating subclass axioms from spreadsheet structures"@en ;
               skos:scopeNote "A configuration template pattern used to auto-generate deep ontological structures directly out of spreadsheet lists."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000088
okea:ont000088 rdf:type owl:Class ;
