###  http://www.ontologyrepository.com/CommonCoreOntologies/TCPHeader
cceo:TCPHeader rdf:type owl:Class ;
               rdfs:subClassOf cceo:PacketHeader ;
               rdfs:label "TCP Header"@en ;
               skos:definition "A Packet Header that is prescribed by the Transmission Control Protocol."@en ;
               cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/TCPThreeWayHandshake
