                 rdfs:subClassOf cceo:WrittenSymbol ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty obo:BFO_0000178 ;
                                   owl:someValuesFrom cceo:Morpheme
                                 ] ;
