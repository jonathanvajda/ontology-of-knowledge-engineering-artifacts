###  http://www.ontologyrepository.com/CommonCoreOntologies/SoftwareFramework
cceo:SoftwareFramework rdf:type owl:Class ;
                       rdfs:subClassOf cceo:SoftwareEngineeringSoftware ;
                       rdfs:label "Software Framework"@en ;
                       skos:definition "A Software Engineering Software that provides generic functionality and can be selectively changed by additional user-written code to provide application-specific functionality."@en ;
                       cco2:ont00001754 "https://en.wikipedia.org/wiki/Software_framework"^^xsd:anyURI ;
                       cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/SoftwareLibrary
cceo:SoftwareLibrary rdf:type owl:Class ;
                     rdfs:subClassOf cco2:ont00000798 ;
                     rdfs:label "Software Library"@en ;
                     skos:definition "An Information Bearing Artifact that is an aggregate of Digital Files and that is designed to support the development or execution of Computer Programs."@en ;
                     skos:example "A collection of digital files consisting of: configuration data and documentation for a program, and pre-written methods and classes which can be called by other programs."@en ;
                     cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/SoftwareStack
cceo:SoftwareStack rdf:type owl:Class ;
                   rdfs:subClassOf cco2:ont00000117 ;
                   rdfs:label "Software Stack"@en ;
                   skos:definition "An Information Processing Artifact composed of software, software subsystems, or components needed to create a complete platform such that no additional software is needed to support applications."@en ;
                   cco2:ont00001754 "https://en.wikipedia.org/wiki/Solution_stack"^^xsd:anyURI ;
                   cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


