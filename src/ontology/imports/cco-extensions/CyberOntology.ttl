                                    cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/Spyware
cceo:Spyware rdf:type owl:Class ;
             rdfs:subClassOf cceo:ComputerProgram ;
             rdfs:label "Spyware"@en ;
             skos:definition "A Computer Program that is designed to gather information about a person or organization without their knowledge, that may send such information to another entity without the consumer's consent, or that asserts control over a device without the consumer's knowledge."@en ;
             cco2:ont00001754 "https://en.wikipedia.org/wiki/Spyware"^^xsd:anyURI ;
             cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/StandardUserAccount
cceo:StandardUserAccount rdf:type owl:Class ;
                         rdfs:subClassOf cceo:UserAccount ;
                         rdfs:label "Standard User Account"@en ;
                         skos:definition "A User Account that is not permitted to create, edit, view, or delete system files."@en ;
                         cco2:ont00001754 "https://www.guidingtech.com/difference-between-standard-user-administrator/"^^xsd:anyURI ;
                         cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/StasisOfDigitalStorage
cceo:StasisOfDigitalStorage rdf:type owl:Class ;
                            rdfs:subClassOf cceo:StasisOfInformationConcretization ;
                            rdfs:label "Stasis of Digital Storage"@en ;
                            skos:definition "A Stasis of Information Bearing that has as participants some Digital Storage Device and some Information Quality Entity."@en ;
                            skos:scopeNote "The purpose of this Stasis is to represent that some Digital Storage Device (e.g., a hard drive or RAM) stores (at a given time) a Computer Program. We cannot say that a Computer Program (an IBA) is part_of some hard drive or RAM, because although the hard drive or RAM might take on qualities in order to encode the Program, the Program itself is not identical to any of those qualities."@en ;
                            cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/StasisOfInformationConcretization
cceo:StasisOfInformationConcretization rdf:type owl:Class ;
                                       rdfs:subClassOf cco2:ont00000335 ;
                                       rdfs:label "Stasis of Information Bearing"@en ;
                                       skos:definition "A Stasis of Generically Dependent Continuant that has as participants some Information Bearing Entity and some Information Content Entity."@en ;
                                       cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


