                 rdfs:subClassOf cceo:OverlayNetwork ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty obo:BFO_0000056 ;
                                   owl:someValuesFrom cceo:Authentication
                                 ] ;
                 rdfs:label "Dark Network"@en ;
                 skos:definition "An Overlay Network that can be accessed only with specific software, configurations, or authorization, often using non-standard communications protocols or ports."@en ;
