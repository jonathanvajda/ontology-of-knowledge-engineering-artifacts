                   rdfs:subClassOf cco2:ont00000798 ;
                   rdfs:label "Node Attribute"@en ;
                   skos:definition "An Information Bearing Artifact that is attached to a Node, and which typically bears information about that Node or what it represents."@en ;
                   cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


