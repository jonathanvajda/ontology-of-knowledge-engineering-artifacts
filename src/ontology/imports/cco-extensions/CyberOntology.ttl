                                            cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/BrowserHijackingProgram
cceo:BrowserHijackingProgram rdf:type owl:Class ;
                             rdfs:subClassOf cceo:Malware ;
                             rdfs:label "Browser Hijacking Program"@en ;
                             skos:definition "Malware that is designed to modify a Web Browser's settings without a user's permission in order to inject unwanted advertising into that Browser."@en ;
                             cco2:ont00001754 "https://en.wikipedia.org/wiki/Browser_hijacking"^^xsd:anyURI ;
                             cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/Byte
cceo:Byte rdf:type owl:Class ;
          rdfs:subClassOf cco2:ont00000798 ;
          rdfs:label "Byte"@en ;
          skos:definition "An Information Bearing Artifact that consists of an ordered collection of eight or fewer Bits."@en ;
          skos:scopeNote "Bytes are almost ubiquitously understood as ordered collections of eight Bits, but there are exceptions where Bytes are understood as ordered collections of fewer than eight Bits."@en ;
          cco2:ont00001754 "https://en.wikipedia.org/wiki/Byte"^^xsd:anyURI ;
          cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CVEVulnerability
cceo:CVEVulnerability rdf:type owl:Class ;
                      owl:equivalentClass [ owl:intersectionOf ( cceo:CyberVulnerability
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty obo:BFO_0000197 ;
                                                                   owl:someValuesFrom [ owl:intersectionOf ( cco2:ont00000117
                                                                                                             [ rdf:type owl:Restriction ;
                                                                                                               owl:onProperty cco2:ont00001920 ;
                                                                                                               owl:someValuesFrom cceo:ComputerProgramArtifactModel
                                                                                                             ]
                                                                                                           ) ;
                                                                                        rdf:type owl:Class
                                                                                      ]
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ] ;
                      rdfs:subClassOf cceo:CyberVulnerability ;
                      rdfs:label "CVE Vulnerability"@en ;
                      rdfs:seeAlso "https://cve.mitre.org/about/index.html"^^xsd:anyURI ;
                      skos:altLabel "Common Vulnerability or Exposure"@en ;
                      skos:definition "A Cyber Vulnerability that inheres in an Information Processing Artifact prescribed by a known Computer Program Artifact Model."@en ;
                      cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CacheMemory
cceo:CacheMemory rdf:type owl:Class ;
                 rdfs:subClassOf cceo:ComputerMemory ;
                 rdfs:label "Cache Memory"@en ;
                 skos:definition "Computer Memory that is fast, relatively small, not visible to software, is completely handled by the hardware, and stores the most recently used main memory data."@en ;
                 cco2:ont00001754 "https://en.wikipedia.org/wiki/Cache_memory"^^xsd:anyURI ;
                 cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CallCenter
cceo:CallCenter rdf:type owl:Class ;
                rdfs:subClassOf cco2:ont00000531 ;
                rdfs:label "Call Center"@en ;
                skos:definition "A Communications Facility that is designed to house Groups of Agents who respond to inquiries for an Organization."@en ;
                cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CentralProcessingUnit
cceo:CentralProcessingUnit rdf:type owl:Class ;
                           rdfs:subClassOf cceo:ProcessingUnit ;
                           rdfs:label "Central Processing Unit"@en ;
                           skos:definition "A Processing Unit that is designed to execute the basic arithmetic, logical, control, and input/output operations prescribed by some Computer Program."@en ;
                           cco2:ont00001754 "https://en.wikipedia.org/wiki/Central_processing_unit"^^xsd:anyURI ;
                           cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ChecksumMeasurement
cceo:ChecksumMeasurement rdf:type owl:Class ;
                         rdfs:subClassOf cco2:ont00001022 ;
                         rdfs:label "Checksum Measurement"@en ;
                         skos:definition "A Ratio Measurement Information Content Entity that is a measurement of the number of bits in a transmission unit that is included with the unit so that the receiver can check to see whether the same number of bits arrived."@en ;
                         cco2:ont00001754 "http://searchsecurity.techtarget.com/definition/checksum"^^xsd:anyURI ;
                         cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ChildComputerProgramExecution
cceo:ChildComputerProgramExecution rdf:type owl:Class ;
                                   owl:equivalentClass [ owl:intersectionOf ( cceo:ComputerProgramExecution
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty cco2:ont00001962 ;
                                                                                owl:someValuesFrom cceo:ComputerProgramExecution
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ] ;
                                   rdfs:subClassOf cceo:ComputerProgramExecution ;
                                   rdfs:label "Child Computer Program Execution"@en ;
                                   skos:altLabel "Child Computer Process"@en ;
                                   skos:definition "A Computer Program Execution that is started by some other Computer Program Execution."@en ;
                                   cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CodeCompilation
cceo:CodeCompilation rdf:type owl:Class ;
                     rdfs:subClassOf cceo:ComputerProgramExecution ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty cceo:has_causal_factor ;
                                       owl:someValuesFrom cceo:CodeCompiler
                                     ] ;
                     rdfs:label "Code Compilation"@en ;
                     skos:definition "A Computer Program Execution in which some Information Bearing Entity that uses a Compiled Language is translated into some Information Bearing Entity that uses a Low-Level Programming Language."@en ;
                     cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CodeCompiler
cceo:CodeCompiler rdf:type owl:Class ;
                  rdfs:subClassOf cceo:SoftwareEngineeringSoftware ;
                  rdfs:label "Code Compiler"@en ;
                  skos:definition "A Software Engineering Application that translates another Computer Program written in one Programming Language into another Programming Language, most often to create an Executable Program."@en ;
                  cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CodeInterpreter
cceo:CodeInterpreter rdf:type owl:Class ;
                     rdfs:subClassOf cceo:SoftwareEngineeringSoftware ;
                     rdfs:label "Code Interpreter"@en ;
                     skos:definition "A Software Engineering Application that directly executes the instructions of some Executable Program without compiling those instructions into some Machine Language."@en ;
                     cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CompiledLanguage
cceo:CompiledLanguage rdf:type owl:Class ;
                      rdfs:subClassOf cceo:HighLevelProgrammingLanguage ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty cco2:ont00001899 ;
                                        owl:someValuesFrom [ owl:intersectionOf ( cceo:ComputerProgram
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty cco2:ont00001816 ;
                                                                                    owl:someValuesFrom cceo:CodeCompilation
                                                                                  ]
                                                                                ) ;
                                                             rdf:type owl:Class
                                                           ]
                                      ] ;
                      owl:disjointWith cceo:InterpretedLanguage ,
                                       cceo:MachineLanguage ;
                      rdfs:label "Compiled Language"@en ;
                      skos:definition "A Programming Language that prescribes a canonical form of communicating instructions to be executed by a Processing Unit in such a way that the Information Bearing Entity that uses this Programming Language must first be the input of some Code Compilation."@en ;
                      cco2:ont00001754 "https://en.wikipedia.org/wiki/Compiled_language"^^xsd:anyURI ;
                      cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CompressedDataFormat
cceo:CompressedDataFormat rdf:type owl:Class ;
                          rdfs:subClassOf cceo:FileFormat ;
                          rdfs:label "Compressed Data Format"@en ;
                          skos:definition "A File Format that prescribes a way of encoding information which uses fewer Bits than the original encoding of that information."@en ;
                          skos:example "A .zip file format"@en ;
                          cco2:ont00001754 "https://en.wikipedia.org/wiki/Data_compression"^^xsd:anyURI ;
                          cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


