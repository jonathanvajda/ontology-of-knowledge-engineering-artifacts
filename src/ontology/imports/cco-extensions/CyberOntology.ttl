                                       rdfs:subClassOf cco2:ont00000847 ;
                                       rdfs:label "Network Communication Waiting Status"@en ;
                                       skos:definition "An Active Stasis in which some resource on a network is waiting to receive messages from other resources it is connected to on that network."@en ;
                                       skos:scopeNote "Instances of this class can be combined with instances of other classes to represent various TCP states, including: CLOSE WAIT, CLOSING, FIN-WAIT-1, FIN-WAIT-2, LAST ACK, SYN RECEIVED, SYN SENT, and TIME WAIT."@en ;
                                       cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


