          rdfs:subClassOf cco2:ont00000798 ;
          rdfs:label "Node"@en ;
          skos:altLabel "Vertex"@en ;
          skos:definition "An Information Bearing Artifact that is a basic element in a graph data structure, which can be connected to other such elements by edges."@en ;
