                      rdfs:label "Cryptanalyst Role"@en ;
                      skos:definition "A Cyber Security Role that inheres in an Agent by virtue of its responsibility to decipher secret codes and write codes that cannot be cracked by hackers"@en ;
                      cco2:ont00001754 "https://www.careerexplorer.com/careers/cryptanalyst/"^^xsd:anyURI ;
                      cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CryptographerRole
cceo:CryptographerRole rdf:type owl:Class ;
                       rdfs:subClassOf cceo:CyberSecurityRole ;
                       rdfs:label "Cryptographer Role"@en ;
                       skos:definition "A Cyber Security Role that inheres in an Agent by virtue of its responsibility to develop algorithms, ciphers and security systems to encrypt sensitive information and provide privacy for people and corporations."@en ;
                       cco2:ont00001754 "https://www.careerexplorer.com/careers/cryptographer/"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberAct
cceo:CyberAct rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( cco2:ont00000005
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty obo:BFO_0000066 ;
                                                           owl:someValuesFrom cco2:ont00000700
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
              rdfs:subClassOf cco2:ont00000005 ;
              <http://purl.org/dc/elements/1.1/contributor> "CUBRC Inc"@en ;
              rdfs:label "Cyber Act"@en ;
              skos:altLabel "Cyber Event"@en ;
              skos:definition "An Act that occurs in or through a Computer Network."@en ;
              skos:scopeNote "Roughly, anything that happens 'within' a Computer Network (a.k.a. Cyber System or Information System) is a Cyber Act."@en ;
              cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberAttack
cceo:CyberAttack rdf:type owl:Class ;
                 rdfs:subClassOf cceo:CyberAct ;
                 rdfs:label "Cyber Attack"@en ;
                 skos:definition "Cyber Attack is a Cyber Act that is malicious and directed at a portion of cyber space."@en ;
                 skos:scopeNote "An act that is intended to caused harm and is wrongful against another without legal justification or excuse."@en ;
                 cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberAttackerRole
cceo:CyberAttackerRole rdf:type owl:Class ;
                       owl:equivalentClass [ rdf:type owl:Restriction ;
                                             owl:onProperty cco2:ont00001787 ;
                                             owl:someValuesFrom cceo:CyberAttack
                                           ] ;
                       rdfs:subClassOf cco2:ont00001017 ;
                       rdfs:label "Cyber Attacker"@en ;
                       skos:definition "A Material Entity that is agent in a Cyber Attack."@en ;
                       cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberDefenderRole
cceo:CyberDefenderRole rdf:type owl:Class ;
                       rdfs:subClassOf cceo:CyberSecurityRole ;
                       rdfs:label "Cyber Defender Role"@en ;
                       skos:definition "A Cyber Security Role that inheres in an Agent by virtue of its responsibility for preventing, detecting and providing timely responses to attacks or threats against computers or computer networks."@en ;
                       cco2:ont00001754 "https://www.techopedia.com/definition/6705/cyber-defense"^^xsd:anyURI ;
                       cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberExploit
cceo:CyberExploit rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                               owl:unionOf ( cco2:ont00000117
                                                                             cco2:ont00000798
                                                                           )
                                                             ]
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty cco2:ont00001925 ;
                                                               owl:someValuesFrom [ owl:intersectionOf ( obo:BFO_0000040
                                                                                                         [ rdf:type owl:Restriction ;
                                                                                                           owl:onProperty cco2:ont00001787 ;
                                                                                                           owl:someValuesFrom cceo:CyberAttack
                                                                                                         ]
                                                                                                       ) ;
                                                                                    rdf:type owl:Class
                                                                                  ]
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf cco2:ont00000995 ;
                  rdfs:label "Cyber Exploit Artifact"@en ;
                  skos:definition "An Artifact that is used by an Agent in a Cyber Attack to facilitate the realization of a Cyber Vulnerability."@en ;
                  cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberObjectiveSpecification
cceo:CyberObjectiveSpecification rdf:type owl:Class ;
                                 rdfs:subClassOf cco2:ont00000476 ;
                                 rdfs:label "Cyber Objective Specification"@en ;
                                 skos:definition "An Objective that prescribes a projected state that some Agent intends to achieve in cyberspace."@en ;
                                 skos:example "Escalated privileges, Updated password."@en .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberPlatform
cceo:CyberPlatform rdf:type owl:Class ;
                   rdfs:subClassOf obo:BFO_0000027 ;
                   rdfs:label "Cyber Platform"@en ;
                   skos:definition "An Object Aggregate which consists of an operating system and underlying hardware determining the physical environment in which software executes."@en ;
                   cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberSecurityAdministratorRole
cceo:CyberSecurityAdministratorRole rdf:type owl:Class ;
                                    rdfs:subClassOf cceo:CyberSecurityRole ;
                                    rdfs:label "Cyber Security Administrator Role"@en ;
                                    skos:definition "A Cyber Security Role that inheres in an Agent by virtue of its responsibility to ensure the network's security, protect against unauthorized access, modification, or destruction, and troubleshoot any access problems."@en ;
                                    cco2:ont00001754 "https://www.betterteam.com/security-administrator-job-description"^^xsd:anyURI ;
                                    cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberSecurityAnalystRole
cceo:CyberSecurityAnalystRole rdf:type owl:Class ;
                              rdfs:subClassOf cceo:CyberSecurityRole ;
                              rdfs:label "Cyber Security Analyst Role"@en ;
                              skos:definition "A Cyber Security Role that inheres in an Agent by virtue of its responsibility to design and implement security systems to protect a company or organization’s computer networks from cyber attacks, and help set and maintain security standards."@en ;
                              cco2:ont00001754 "https://www.betterteam.com/information-security-analyst-job-description"^^xsd:anyURI ;
                              cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberSecurityArchitectRole
cceo:CyberSecurityArchitectRole rdf:type owl:Class ;
                                rdfs:subClassOf cceo:CyberSecurityRole ;
                                rdfs:label "Cyber Security Architect Role"@en ;
                                skos:definition "A Cyber Security Role that inheres in an Agent by virtue of its responsibility to design, build and oversee the implementation of network and computer security for an organization."@en ;
                                cco2:ont00001754 "https://www.cyberdegrees.org/jobs/security-architect/"^^xsd:anyURI ;
                                cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberSecurityConsultantRole
cceo:CyberSecurityConsultantRole rdf:type owl:Class ;
                                 rdfs:subClassOf cceo:CyberSecurityRole ;
                                 rdfs:label "Cyber Security Consultant Role"@en ;
                                 skos:definition "A Cyber Security Role that inheres in an Agent by virtue of its responsibility to design and implement the best security solutions for an organization’s needs as well as talk to stakeholders, draw up budgets, supervise teams, and conduct research."@en ;
                                 cco2:ont00001754 "https://www.cyberdegrees.org/jobs/security-consultant/"^^xsd:anyURI ;
                                 cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberSecurityEngineerRole
cceo:CyberSecurityEngineerRole rdf:type owl:Class ;
                               rdfs:subClassOf cceo:CyberSecurityRole ;
                               rdfs:label "Cyber Security Engineer Role"@en ;
                               skos:definition "A Cyber Security Role that inheres in an Agent by virtue of its responsibility to help businesses by protecting their computer and networking systems from potential hackers and cyber-attacks."@en ;
                               cco2:ont00001754 "https://www.betterteam.com/cyber-security-engineer-job-description"^^xsd:anyURI ;
                               cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberSecurityProtectionPlan
cceo:CyberSecurityProtectionPlan rdf:type owl:Class ;
                                 rdfs:subClassOf cco2:ont00000974 ;
                                 rdfs:label "Cyber Security Protection Plan"@en ;
                                 skos:altLabel "Cyber Security Standard"@en ;
                                 skos:definition "A Plan that prescribes Acts which protect the cyber environment of a user or organization."@en ;
                                 skos:scopeNote "This environment includes users themselves, networks, devices, all software, processes, information in storage or transit, applications, services, and systems that can be connected directly or indirectly to networks."@en ;
                                 cco2:ont00001754 "https://en.wikipedia.org/wiki/Cyber_security_standards"^^xsd:anyURI ;
                                 cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberSecurityRole
cceo:CyberSecurityRole rdf:type owl:Class ;
                       rdfs:subClassOf obo:BFO_0000023 ;
                       rdfs:label "Cyber Security Role"@en ;
                       skos:definition "A Role that is realized in an Act wherein its bearer attempts to prevent and mitigate Cyber Attacks."@en ;
                       cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberSecuritySoftwareDeveloperRole
cceo:CyberSecuritySoftwareDeveloperRole rdf:type owl:Class ;
                                        rdfs:subClassOf cceo:CyberSecurityRole ;
                                        rdfs:label "Cyber Security Software Developer Role"@en ;
                                        skos:definition "A Cyber Security Role that inheres in an Agent by virtue of its responsibility to develop security software and integrates security into applications software during the course of design and development."@en ;
                                        cco2:ont00001754 "https://www.cyberdegrees.org/jobs/security-software-developer/"^^xsd:anyURI ;
                                        cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberThreatNominalMeasurement
cceo:CyberThreatNominalMeasurement rdf:type owl:Class ;
                                   rdfs:subClassOf cco2:ont00000293 ;
                                   rdfs:label "Cyber Threat Nominal Measurement"@en ;
                                   skos:definition "A Nominal Measurement Information Content Entity that is about the potential impact of a Cyber Vulnerability when realized in a Cyber Attack."@en ;
                                   cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CyberVulnerability
cceo:CyberVulnerability rdf:type owl:Class ;
                        rdfs:subClassOf cco2:ont00000548 ,
                                        [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                 owl:onProperty obo:BFO_0000054 ;
                                                                 owl:someValuesFrom cceo:CyberAttack
                                                               ]
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty obo:BFO_0000054 ;
                                                                 owl:allValuesFrom cceo:CyberAttack
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                        rdfs:label "Cyber Vulnerability"@en ;
                        rdfs:seeAlso "https://cwe.mitre.org/about/index.html"^^xsd:anyURI ;
                        skos:altLabel "Common Software Weakness"@en ;
                        skos:definition "A Vulnerability that is realized by a Cyber Attack interfering with or destroying a device's ability to function normally."@en ;
                        cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CybersecurityAct
cceo:CybersecurityAct rdf:type owl:Class ;
                      rdfs:subClassOf cceo:CyberAct ;
                      dcterms:creator "CUBRC Inc"@en ;
                      rdfs:label "Cybersecurity Act"@en ;
                      skos:altLabel "Cybersecurity Event"@en ;
                      skos:definition "A Cyber Act that affects the security of a Computer Network or the information residing therein."@en ;
                      skos:scopeNote "‘Security’ is most likely a realizable entity that inheres in its bearer (in this case, a Computer Network) and gets realized by various processes. NOTE: defining 'Security' or 'Cybersecurity' is necessary in order to create an equivalency axiom for 'Cybersecurity Act'."@en ;
                      cco2:ont00001754 "https://csrc.nist.gov/glossary/term/cybersecurity_event"^^xsd:anyURI ,
                                       "https://www.bitlyft.com/resources/security-incident-vs-event-what-is-the-difference"^^xsd:anyURI ;
                      cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CybersecurityIncident
cceo:CybersecurityIncident rdf:type owl:Class ;
                           owl:equivalentClass [ owl:intersectionOf ( cceo:CybersecurityAct
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty cco2:ont00001803 ;
                                                                        owl:someValuesFrom cco2:ont00001289
                                                                      ]
                                                                    ) ;
                                                 rdf:type owl:Class
                                               ] ;
                           rdfs:subClassOf cceo:CybersecurityAct ;
                           dcterms:creator "CUBRC Inc"@en ;
                           rdfs:comment """TO DO: Add a term(s) for Confidentiality, Integrity, and Accessibility (CIA) of data. Then use these terms to refine the definition of Cybersecurity Incident.

This is needed because scoping the range of consequences that make a Cyber Act qualify as a Cybersecurity Incident is challenging. For example, consider a scenario where a major credit reporting agency experiences a data breach/spill that affects millions of people but at least some of those people are not owners/users/etc. of that database. Damage is done and this should be typed as a Cybersecurity Incident, but how do we capture these \"outside\" agents without making the definition too broad? For example, we probably don't want to include cyber bullying that causes real world harm as Cybersecurity Incidents."""@en ;
                           rdfs:label "Cybersecurity Incident"@en ;
                           skos:altLabel "Cyber Attack Consequence"@en ;
                           skos:definition "A Cybersecurity Act that causes an adverse effect to a Computer Network, the information residing therein, or its authorized users or owners."@en ;
                           skos:example "a data breach or data spill"@en ,
                                        "the outcome of a successful cyber attack"@en ;
                           cco2:ont00001754 "https://csrc.nist.gov/glossary/term/cyber_incident"^^xsd:anyURI ,
                                            "https://www.bitlyft.com/resources/security-incident-vs-event-what-is-the-difference"^^xsd:anyURI ;
                           cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CybersecurityInfraction
cceo:CybersecurityInfraction rdf:type owl:Class ;
                             owl:equivalentClass [ owl:intersectionOf ( cceo:CybersecurityAct
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty cco2:ont00001803 ;
                                                                          owl:someValuesFrom [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                                                                                      owl:unionOf ( cco2:ont00000609
                                                                                                                                    cco2:ont00001356
                                                                                                                                  )
                                                                                                                    ]
                                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                                      owl:onProperty cco2:ont00001778 ;
                                                                                                                      owl:someValuesFrom cceo:CyberVulnerability
                                                                                                                    ]
                                                                                                                  ) ;
                                                                                               rdf:type owl:Class
                                                                                             ]
                                                                        ]
                                                                      ) ;
                                                   rdf:type owl:Class
                                                 ] ;
                             rdfs:subClassOf cceo:CybersecurityAct ;
                             dcterms:creator "CUBRC Inc"@en ;
                             rdfs:label "Cybersecurity Infraction"@en ;
                             skos:altLabel "Cybersecurity Escape"@en ;
                             skos:definition "A Cybersecurity Act that decreases the security of a Computer Network by creating a new Cyber Vulnerability or increasing an existing Cyber Vulnerability that inheres in that Computer Network."@en ;
                             skos:example "creating a weak password or reusing passwords"@en ,
                                          "failing to set appropriate network access permissions"@en ,
                                          "leaving a networked device unlocked and unattended in a public space"@en ;
                             skos:scopeNote "This class is designed to disambiguate between Cyber Acts that MIGHT cause damage (i.e., Cybersecurity Infraction) from Cyber Acts that DO cause damage (i.e., Cybersecurity Incident)."@en ;
                             cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CybersecurityProcess
cceo:CybersecurityProcess rdf:type owl:Class ;
                          owl:equivalentClass [ owl:intersectionOf ( cceo:CybersecurityAct
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty cco2:ont00001803 ;
                                                                       owl:someValuesFrom [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                                                                                   owl:unionOf ( cco2:ont00000543
                                                                                                                                 cco2:ont00001066
                                                                                                                               )
                                                                                                                 ]
                                                                                                                 [ rdf:type owl:Restriction ;
                                                                                                                   owl:onProperty cco2:ont00001778 ;
                                                                                                                   owl:someValuesFrom cceo:CyberVulnerability
                                                                                                                 ]
                                                                                                               ) ;
                                                                                            rdf:type owl:Class
                                                                                          ]
                                                                     ]
                                                                   ) ;
                                                rdf:type owl:Class
                                              ] ;
                          rdfs:subClassOf cceo:CybersecurityAct ;
                          dcterms:creator "CUBRC Inc"@en ;
                          rdfs:label "Cybersecurity Process"@en ;
                          skos:definition "A Cybersecurity Act that is performed to increase the security of a Computer Network."@en ;
                          skos:example "a password verification process intended to prevent the creation of weak passwords"@en ,
                                       "deploying a firewall for a computer network"@en ,
                                       "running a malware scan"@en ;
                          cco2:ont00001754 "https://csrc.nist.gov/glossary/term/cybersecurity"^^xsd:anyURI ,
                                           "https://nvlpubs.nist.gov/nistpubs/CSWP/NIST.CSWP.04162018.pdf"^^xsd:anyURI ;
                          cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/CybersecurityViolation
cceo:CybersecurityViolation rdf:type owl:Class ;
                            rdfs:subClassOf cceo:CybersecurityAct ;
                            dcterms:creator "CUBRC Inc"@en ;
                            rdfs:comment "Creating an equivalency axiom for Cybersecurity Violation requires creating a term such as 'Cybersecurity Policy'."@en ;
                            rdfs:label "Cybersecurity Violation"@en ;
                            skos:definition "A Cybersecurity Act that violates the Computer Network owner's Cybersecurity Policy."@en ;
                            skos:example "failing to follow the exact steps outlined by the security policy for a procedure"@en ,
                                         "plugging an unapproved device into a company computer"@en ,
                                         "using a secure information system to access a personal social media account"@en ;
                            skos:scopeNote "Cybersecurity Violations are differentiated from Cybersecurity Infractions because violations are specific to organizational policies. Not every act that violates a Cybersecurity Policy necessarily has a negative effect on the security of a Computer Network. Similarly, it is unlikely that any given Cybersecurity Policy is capable of documenting every possible action that would negatively affect a Computer Network. Hence, these classes are distinct despite having many instances in common."@en ;
                            cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/DHCPServiceFunction
