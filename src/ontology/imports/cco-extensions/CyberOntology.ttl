###  http://www.ontologyrepository.com/CommonCoreOntologies/MaliciousAdware
cceo:MaliciousAdware rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( cceo:Adware
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty cco2:ont00001787 ;
                                                                  owl:someValuesFrom cceo:CyberAttack
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     rdfs:subClassOf cceo:Adware ;
                     rdfs:label "Malicious Adware"@en ;
                     skos:definition "Adware that is an agent in some Cyber Attack.."@en ;
                     cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/MaliciousCode
cceo:MaliciousCode rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( cceo:Subroutine
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty cco2:ont00001841 ;
                                                                owl:someValuesFrom cceo:CyberAttack
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                   rdfs:subClassOf cceo:Subroutine ;
                   rdfs:label "Malicious Code"@en ;
                   skos:definition "A Subroutine that is input of a Cyber Attack."@en ;
                   cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/MaliciousSpyware
cceo:MaliciousSpyware rdf:type owl:Class ;
                      owl:equivalentClass [ owl:intersectionOf ( cceo:Spyware
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty cco2:ont00001787 ;
                                                                   owl:someValuesFrom cceo:CyberAttack
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ] ;
                      rdfs:subClassOf cceo:Spyware ;
                      rdfs:label "Malicious Spyware"@en ;
                      skos:definition "Spyware that is an agent in a Cyber Attack."@en ;
                      cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/Malware
cceo:Malware rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( cceo:ComputerProgram
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty cco2:ont00001787 ;
                                                          owl:someValuesFrom cceo:CyberAttack
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf cceo:ComputerProgram ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty obo:BFO_0000178 ;
                               owl:someValuesFrom cceo:MaliciousCode
                             ] ;
             rdfs:label "Malware"@en ;
             skos:definition "A Computer Program that is an agent in a Cyber Attack."@en ;
             cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


