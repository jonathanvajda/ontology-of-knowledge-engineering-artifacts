###  http://www.ontologyrepository.com/CommonCoreOntologies/ProgrammingLanguage
cceo:ProgrammingLanguage rdf:type owl:Class ;
                         rdfs:subClassOf cceo:ComputerLanguage ;
                         rdfs:label "Programming Language"@en ;
                         skos:definition "A Computer Language that prescribes a canonical form of communicating instructions to be executed by some Processing Unit or by a Computer Program."@en ;
                         cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ProgrammingMethod
cceo:ProgrammingMethod rdf:type owl:Class ;
                       rdfs:subClassOf cceo:Subroutine ;
                       rdfs:label "Programming Method"@en ;
                       skos:altLabel "Method"@en ;
                       skos:definition "A Subroutine that is part of a Computer Object."@en ;
                       cco2:ont00001754 "https://en.wikipedia.org/wiki/Method_(computer_programming)"^^xsd:anyURI ;
                       cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ProxyFirewall
cceo:ProxyFirewall rdf:type owl:Class ;
                   rdfs:subClassOf cceo:Firewall ;
                   rdfs:label "Proxy Firewall"@en ;
                   skos:altLabel "Application Firewall"@en ,
                                 "Gateway Firewall"@en ;
                   skos:definition "A Firewall that protects network resources by filtering messages at the application layer using stateful inspection technology and deep packet inspection."@en ;
                   cco2:ont00001754 "http://searchsecurity.techtarget.com/definition/proxy-firewall"^^xsd:anyURI ;
                   cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/QueryLanguage
cceo:QueryLanguage rdf:type owl:Class ;
                   rdfs:subClassOf cceo:ComputerLanguage ;
                   rdfs:label "Query Language"@en ;
                   skos:definition "A Computer language used to make queries in databases and information systems."@en ;
                   cco2:ont00001754 "https://en.wikipedia.org/wiki/Query_language"^^xsd:anyURI ;
                   cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/RandomAccessMemory
cceo:RandomAccessMemory rdf:type owl:Class ;
                        rdfs:subClassOf cceo:ComputerMemory ;
                        rdfs:label "Random-Access Memory"@en ;
                        skos:definition "Computer Memory that stores frequently used Computer Programs to increase the general speed of a Computer."@en ;
                        cco2:ont00001753 "RAM"@en ;
                        cco2:ont00001754 "https://en.wikipedia.org/wiki/Random-access_memory"^^xsd:anyURI ;
                        cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/Ransomware
cceo:Ransomware rdf:type owl:Class ;
                rdfs:subClassOf cceo:Malware ;
                rdfs:label "Ransomware"@en ;
                skos:definition "Malware that is designed to lock a user out of a computer system, and threaten to publish the victim's data or perpetually block system access unless a ransom is paid."@en ;
                cco2:ont00001754 "https://en.wikipedia.org/wiki/Ransomware"^^xsd:anyURI ;
                cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ReadFilePermission
cceo:ReadFilePermission rdf:type owl:Class ;
                        rdfs:subClassOf cceo:FilePermission ;
                        rdfs:label "Read File Permission"@en ;
                        skos:definition "A File Permission that prescribes the reading of a file by a user account."@en ;
                        cco2:ont00001754 "https://en.wikipedia.org/wiki/File_system_permissions"^^xsd:anyURI ;
                        cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/RelationalDatabaseSoftwareApplicationModel
cceo:RelationalDatabaseSoftwareApplicationModel rdf:type owl:Class ;
                                                rdfs:subClassOf cceo:DatabaseSoftwareApplicationModel ;
                                                rdfs:label "Relational Database Software Application"@en ;
                                                skos:definition "A Database Software Application that prescribes a Database Software Application where the data is stored as a set of linked tables, or relations, that contain attributes, or columns, along with identifying keys that can be use to write queries to return joined and trimmed subsets of the database contents."@en ;
                                                cco2:ont00001754 "https://searchdatamanagement.techtarget.com/definition/relational-database"^^xsd:anyURI ;
                                                cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/RemoteAccess
cceo:RemoteAccess rdf:type owl:Class ;
                  rdfs:subClassOf cceo:ComputerProgramExecution ;
                  rdfs:label "Remote Access"@en ;
                  skos:definition "A Computer Program Execution in which an Information Processing Artifact at one location connects with some other Information Processing Artifact at some other, remote location."@en ;
                  cco2:ont00001754 "https://en.wikipedia.org/wiki/Remote_access"^^xsd:anyURI ;
                  cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/RemoteAccessServiceFunction
cceo:RemoteAccessServiceFunction rdf:type owl:Class ;
                                 rdfs:subClassOf cceo:NetworkServiceFunction ;
                                 rdfs:label "Remote Access Service Function"@en ;
                                 skos:altLabel "Remote Access Service"@en ;
                                 skos:definition "A Network Service Function that when realized is in a process of a Computer remotely accessing and controling another Computer on a Computer Network."@en ;
                                 cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/RemoteAccessTool
cceo:RemoteAccessTool rdf:type owl:Class ;
                      rdfs:subClassOf cceo:ApplicationSoftware ;
                      rdfs:label "Remote Access Tool"@en ;
                      skos:altLabel "RAT"@en ,
                                    "Remote Administration Software"@en ;
                      skos:definition "Application Software that allows a remote operator to control a system."@en ;
                      cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/RemoteTerminalUnit
cceo:RemoteTerminalUnit rdf:type owl:Class ;
                        rdfs:subClassOf cco2:ont00000420 ;
                        rdfs:label "Remote Terminal Unit"@en ;
                        skos:altLabel "RTU"@en ;
                        skos:definition "A Computer that is designed to interface objects in the physical world to a Distributed Control System or a SCADA System by transmitting telemetry data to a master system, and by using messages from the master supervisory system to control connected objects."@en ;
                        cco2:ont00001754 "https://en.wikipedia.org/wiki/Remote_terminal_unit"^^xsd:anyURI ;
                        cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


