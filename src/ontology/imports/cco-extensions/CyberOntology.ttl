###  http://www.ontologyrepository.com/CommonCoreOntologies/PackageManager
cceo:PackageManager rdf:type owl:Class ;
                    rdfs:subClassOf cceo:UtilityProgram ;
                    rdfs:label "Package Manager"@en ;
                    skos:definition "A Utility Program that is designed to automate the process of installing, upgrading, configuring, and removing Computer Programs for a Computer's Operating System."@en ;
                    cco2:ont00001754 "https://en.wikipedia.org/wiki/Package_manager"^^xsd:anyURI ;
                    cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/PacketHeader
cceo:PacketHeader rdf:type owl:Class ;
                  rdfs:subClassOf cceo:InformationHeader ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:BFO_0000176 ;
                                    owl:someValuesFrom cceo:NetworkPacket
                                  ] ;
                  rdfs:label "Packet Header"@en ;
                  skos:definition "A Information Header that is part of some Computer Packet."@en ;
                  cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/PacketTransfer
cceo:PacketTransfer rdf:type owl:Class ;
                    rdfs:subClassOf cceo:DataTransfer ;
                    rdfs:label "Packet Transfer"@en ;
                    skos:definition "A Data Transfer in which a Network Packet is transmitted from one Computer to another."@en ;
                    cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ParentComputerProgramExecution
cceo:ParentComputerProgramExecution rdf:type owl:Class ;
                                    owl:equivalentClass [ owl:intersectionOf ( cceo:ComputerProgramExecution
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty cco2:ont00001933 ;
                                                                                 owl:someValuesFrom cceo:ComputerProgramExecution
                                                                               ]
                                                                             ) ;
                                                          rdf:type owl:Class
                                                        ] ;
                                    rdfs:subClassOf cceo:ComputerProgramExecution ;
                                    rdfs:label "Parent Computer Program Execution"@en ;
                                    skos:altLabel "Parent Computer Process"@en ;
                                    skos:definition "A Computer Program Execution that starts some other Computer Program Execution."@en ;
                                    cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/PassbandBandwidthMeasurement
cceo:PassbandBandwidthMeasurement rdf:type owl:Class ;
                                  rdfs:subClassOf cceo:SignalBandwidthMeasurement ;
                                  rdfs:label "Passband Bandwidth Measurement"@en ;
                                  skos:definition "A Signal Bandwidth Measurement that is a measurement of the range of continuous Frequencies between some upper and lower cutoff Frequencies."@en ;
                                  cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/Pathname
cceo:Pathname rdf:type owl:Class ;
              rdfs:subClassOf cco2:ont00000077 ;
              rdfs:label "Pathname"@en ;
              skos:definition "A Code Identifier that designates a Digital File or File System Directory by specifying where that item is located within a hierarchy of File System Directories."@en ;
              skos:example "C:/john.doe/Documents/myDocument.doc"@en ;
              cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/PeerToPeerNetwork
cceo:PeerToPeerNetwork rdf:type owl:Class ;
                       rdfs:subClassOf cceo:OverlayNetwork ;
                       rdfs:label "Peer-to-Peer Network"@en ;
                       skos:altLabel "P2P Network"@en ;
                       skos:definition "An Overlay Network that partitions tasks or workloads between equally privileged peers on the network."@en ;
                       cco2:ont00001754 "https://en.wikipedia.org/wiki/Peer-to-peer"^^xsd:anyURI ;
                       cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


