cceo:RootDirectory rdf:type owl:Class ;
                   rdfs:subClassOf cceo:FileSystemDirectory ;
                   rdfs:label "Root Directory"@en ;
                   skos:definition "A File System Directory that is the first or top-most directory in a hierarchy of File System Directories."@en ;
                   cco2:ont00001754 "https://en.wikipedia.org/wiki/Root_directory"^^xsd:anyURI ;
                   cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


