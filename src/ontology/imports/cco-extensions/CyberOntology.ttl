                                                                               rdfs:label "Cyber Ontology"@en ;
                                                                               owl:versionInfo "Compatible with Common Core Ontologies Version 2.0"@en ,
                                                                                               "March 4, 2025"@en ;
                                                                               skos:scopeNote "The Cyber Ontology is designed to serve as a domain-level reference for representing entities relevant to the digitization, manipulation, and transfer of information using telecommunication networks, especially as they pertain to activities in cyberspace. Examples include: information processing artifacts and their functions, networks and their components, software, protocols and standards, users and their permissions, data transformation and encoding, cyber attacks and their objectives."@en ,
                                                                                              "There are at least three unique senses of 'cyberspace': the interconnected physical devices that make up a telecommunication network; a space within those systems, presumably where electromagnetic energy flows; and the logical space of sequences and patterns of structured information carriers within that flow of energy. This last sense is analogous to the propagation of sound waves through the air or ripples in a pond and is closest to the view referred to within the defining elements of this ontology. However, all three may be applicable to articulate enties relevant to the cyber domain. Thus, we do not attempt to define 'cyberspace' formally and leave it as primitive. See Here: https://csrc.nist.gov/glossary/term/cyberspace."@en .

#################################################################
#    Object Properties
#################################################################

###  http://www.ontologyrepository.com/CommonCoreOntologies/file_attachment_of
cceo:file_attachment_of rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf obo:BFO_0000176 ;
                        owl:inverseOf cceo:has_file_attachment ;
                        rdfs:label "file attachment of"@en ;
                        cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/format_used_in
cceo:format_used_in rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf cco2:ont00001942 ;
                    owl:inverseOf cceo:uses_format ;
                    rdfs:label "format used in"@en ;
                    cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/has_causal_factor
cceo:has_causal_factor rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf obo:BFO_0000057 ;
                       owl:inverseOf cceo:is_causal_factor_in ;
                       rdfs:label "has causal factor"@en ;
                       cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/has_child_node
cceo:has_child_node rdf:type owl:ObjectProperty ;
                    owl:inverseOf cceo:has_parent_node ;
                    rdfs:label "has child node"@en ;
                    cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/has_file_attachment
cceo:has_file_attachment rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf obo:BFO_0000178 ;
                         rdfs:label "has file attachment"@en ;
                         cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/has_node_attribute
cceo:has_node_attribute rdf:type owl:ObjectProperty ;
                        owl:inverseOf cceo:node_attribute_of ;
                        rdfs:label "has node attribute"@en ;
                        cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/has_parent_node
cceo:has_parent_node rdf:type owl:ObjectProperty ;
                     rdfs:label "has parent node"@en ;
                     cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/is_causal_factor_in
cceo:is_causal_factor_in rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf obo:BFO_0000056 ;
                         rdfs:label "is causal factor in"@en ;
                         cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/node_attribute_of
cceo:node_attribute_of rdf:type owl:ObjectProperty ;
                       rdfs:label "node attribute of"@en ;
                       cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/uses_format
cceo:uses_format rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf cco2:ont00001920 ;
                 rdfs:label "uses format"@en ;
                 cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


#################################################################
#    Classes
#################################################################

###  http://www.ontologyrepository.com/CommonCoreOntologies/AccessReader
cceo:AccessReader rdf:type owl:Class ;
                  rdfs:subClassOf cco2:ont00000117 ;
                  rdfs:label "Access Reader"@en ;
                  skos:definition "An Information Processing Artifact that is designed to process whether a prospective user has the creditials to access some resource."@en ;
                  skos:scopeNote "Access may be to a physical resource (e.g., a room) or to a virtual resource."@en ;
                  cco2:ont00001754 "https://en.wikipedia.org/wiki/Card_reader#Access_control_card_reader"^^xsd:anyURI ;
                  cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ActOfArtifactCreation
cceo:ActOfArtifactCreation rdf:type owl:Class ;
                           rdfs:subClassOf cco2:ont00000908 ;
                           rdfs:label "Act of Artifact Creation"@en ;
                           skos:definition "An Act of Artifact Processing that consists of bringing a new Artifact into existence."@en ;
                           cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ActOfArtifactDestruction
cceo:ActOfArtifactDestruction rdf:type owl:Class ;
                              rdfs:subClassOf cco2:ont00000908 ;
                              rdfs:label "Act of Artifact Destruction"@en ;
                              skos:definition "An Act of Artifact Processing that consists of destroying some Artifact."@en ;
                              cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ActOfComputerProgramCreation
cceo:ActOfComputerProgramCreation rdf:type owl:Class ;
                                  rdfs:subClassOf cceo:ActOfArtifactCreation ;
                                  rdfs:label "Act Of Computer Software Creation"@en ;
                                  skos:definition "An Intentional Act wherin some Agent develops a Computer Program."@en ;
                                  cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ActOfCyberExploitation
cceo:ActOfCyberExploitation rdf:type owl:Class ;
                            rdfs:subClassOf cco2:ont00000228 ;
                            rdfs:label "Act of Cyber Exploitation"@en ;
                            skos:definition "An Intentional Act that is part of a Cyber Attack wherein a Cyber Attacker uses a Cyber Exploit Artifact to realize a Cyber Vulnerability."@en ;
                            cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ActOfCyberThreatDetection
cceo:ActOfCyberThreatDetection rdf:type owl:Class ;
                               rdfs:subClassOf cco2:ont00001251 ;
                               rdfs:label "Act Of Cyber Threat Detection"@en ;
                               skos:definition "An Act of Intelligence Gathering wherein an Agent attempts to detect cyber threats."@en ;
                               cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ActOfCyberThreatMitigation
cceo:ActOfCyberThreatMitigation rdf:type owl:Class ;
                                owl:equivalentClass [ owl:intersectionOf ( cceo:ActOfInhibiting
                                                                           [ rdf:type owl:Restriction ;
                                                                             owl:onProperty cco2:ont00001959 ;
                                                                             owl:someValuesFrom cceo:CyberAttack
                                                                           ]
                                                                         ) ;
                                                      rdf:type owl:Class
                                                    ] ;
                                rdfs:subClassOf cceo:ActOfInhibiting ;
                                rdfs:label "Act of Cyber Threat Mitigation"@en ;
                                skos:definition "An Intentional Act which inhibits a Cyber Attack."@en ;
                                cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ActOfEvasion
cceo:ActOfEvasion rdf:type owl:Class ;
                  rdfs:subClassOf cco2:ont00000228 ;
                  rdfs:label "Act of Evasion"@en ;
                  skos:definition "An Intentional Act of attempting to avoid an entity."@en ;
                  cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ActOfExperimentation
cceo:ActOfExperimentation rdf:type owl:Class ;
                          rdfs:subClassOf cco2:ont00000228 ;
                          rdfs:label "Act of Experimentation"@en ;
                          skos:definition "An Intentional Act wherein an Agent tests new ideas, methods, or activities, in an attempt to discover new information or knowledge."@en ;
                          cco2:ont00001754 "https://www.lexico.com/en/definition/experimentation"^^xsd:anyURI ;
                          cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ActOfInhibiting
cceo:ActOfInhibiting rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( cco2:ont00000228
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty cco2:ont00001959 ;
                                                                  owl:someValuesFrom obo:BFO_0000015
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     rdfs:subClassOf cco2:ont00000228 ;
                     rdfs:label "Act of Inhibiting"@en ;
                     skos:altLabel "Act of Mitigation"@en ;
                     skos:definition "An Intentional Act that inhibits some Process."@en ;
                     cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ActOfSearching
cceo:ActOfSearching rdf:type owl:Class ;
                    rdfs:subClassOf cco2:ont00000228 ;
                    rdfs:label "Act of Searching"@en ;
                    skos:definition "An Intentional Act of trying to find an entity."@en ;
                    cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/Adware
cceo:Adware rdf:type owl:Class ;
            rdfs:subClassOf cceo:ComputerProgram ;
            rdfs:label "Adware"@en ;
            skos:definition "A Computer Program that is designed to generate revenue for its developer by automatically generating online advertisements in the user interface of the software or on a screen presented to the user during the installation process."@en ;
            cco2:ont00001754 "https://en.wikipedia.org/wiki/Adware"^^xsd:anyURI ;
            cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/AggregationFunction
cceo:AggregationFunction rdf:type owl:Class ;
                         rdfs:subClassOf cco2:ont00000653 ;
                         rdfs:label "Aggregation Function"@en ;
                         skos:definition "An Algorithm in which the values of multiple rows are grouped together to form a single value of more significant meaning."@en ;
                         cco2:ont00001754 "https://en.wikipedia.org/wiki/Aggregate_function"^^xsd:anyURI ;
                         cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/AggregationProcess
cceo:AggregationProcess rdf:type owl:Class ;
                        rdfs:subClassOf cceo:ComputerProgramExecution ;
                        rdfs:label "Aggregation Process"@en ;
                        skos:definition "A Computer Program Execution in which the values of multiple rows are grouped together to form a single value of more significant meaning."@en ;
                        cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/AnimationSoftwareApplication
cceo:AnimationSoftwareApplication rdf:type owl:Class ;
                                  rdfs:subClassOf cceo:MultimediaSoftwareApplication ;
                                  rdfs:label "Animation Software Application"@en ;
                                  skos:definition "A Multimedia Software Application that is designed to enable a user to create and edit animations."@en ;
                                  cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/AnonymityNetwork
cceo:AnonymityNetwork rdf:type owl:Class ;
                      rdfs:subClassOf cceo:DarkNetwork ;
                      rdfs:label "Anonymity Network"@en ;
                      skos:definition "A Dark Network that enables users to access the Internet while blocking any tracking or tracing of their identity."@en ;
                      cco2:ont00001754 "https://www.techopedia.com/definition/25187/anonymity-network"^^xsd:anyURI ;
                      cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/Anonymization
cceo:Anonymization rdf:type owl:Class ;
                   rdfs:subClassOf cceo:ComputerProgramExecution ;
                   rdfs:label "Anonymization"@en ;
                   skos:definition "A Computer Program Execution that encrypts or removes personally identifiable information from data sets in order to maintain the anonymity of the people described by the data."@en ;
                   cco2:ont00001754 "https://en.wikipedia.org/wiki/Data_anonymization"^^xsd:anyURI ;
                   cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/Anonymizer
cceo:Anonymizer rdf:type owl:Class ;
                rdfs:subClassOf cceo:ApplicationSoftware ;
                rdfs:label "Anonymizer"@en ;
                skos:definition "Application Software that is designed to conceal the identity of some client from some Computer Network."@en ;
                cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/AntivirusApplication
cceo:AntivirusApplication rdf:type owl:Class ;
                          rdfs:subClassOf cceo:UtilityProgram ;
                          rdfs:label "Antivirus Application"@en ;
                          skos:altLabel "Anti-malware Software"@en ;
                          skos:definition "A Utility Program that is designed to prevent, detect, and remove malicious software."@en ;
                          cco2:ont00001754 "https://en.wikipedia.org/wiki/Antivirus_software"^^xsd:anyURI ;
                          cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ApplicationBinaryInterface
cceo:ApplicationBinaryInterface rdf:type owl:Class ;
                                rdfs:subClassOf cco2:ont00000319 ;
                                rdfs:label "Application Binary Interface"@en ;
                                skos:altLabel "ABI"@en ;
                                skos:definition "An Artifact Design that is a specification for how to enable a Computer Library and/or Operating System to interact with a Computer Program."@en ;
                                cco2:ont00001754 "https://en.wikipedia.org/wiki/Application_binary_interface"^^xsd:anyURI ;
                                cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ApplicationManager
cceo:ApplicationManager rdf:type owl:Class ;
                        rdfs:subClassOf cceo:UtilityProgram ;
                        rdfs:label "Application Manager"@en ;
                        skos:definition "A Utility Program that is designed to oversee the installation, patching, updating, and accessibility of software applications."@en ;
                        cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ApplicationProgrammingInterface
cceo:ApplicationProgrammingInterface rdf:type owl:Class ;
                                     rdfs:subClassOf cco2:ont00000798 ;
                                     rdfs:label "Application Programming Interface"@en ;
                                     skos:altLabel "API"@en ;
                                     cco2:ont00001754 "https://en.wikipedia.org/wiki/Application_programming_interface"^^xsd:anyURI ;
                                     cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ApplicationSoftware
cceo:ApplicationSoftware rdf:type owl:Class ;
                         rdfs:subClassOf cceo:ComputerProgram ;
                         rdfs:label "Application Software"@en ;
                         skos:altLabel "App"@en ,
                                       "Application"@en ,
                                       "Application Program"@en ,
                                       "Software"@en ,
                                       "Software Application"@en ,
                                       "Software Program"@en ;
                         skos:definition "A Computer Prgoram that is designed to execute a group of coordinated Computer Functions for the benefit of a user."@en ;
                         cco2:ont00001754 "https://en.wikipedia.org/wiki/Application_software"^^xsd:anyURI ;
                         cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/Array
cceo:Array rdf:type owl:Class ;
           rdfs:subClassOf cco2:ont00000798 ;
           rdfs:label "Array"@en ;
           skos:definition "An Information Bearing Artifact that is the bearer of a finite ordered list of Information Content Entities."@en ;
           cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/AssemblyLanguage
cceo:AssemblyLanguage rdf:type owl:Class ;
                      rdfs:subClassOf cceo:LowLevelProgrammingLanguage ;
                      rdfs:label "Assembly Language"@en ;
                      skos:definition "A Programming Language that prescribes a canonical form of communicating instructions which have been translated from a High-Level Programming Language and which can be translated into some Machine Language."@en ;
                      cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/AudioEditingSoftwareApplication
cceo:AudioEditingSoftwareApplication rdf:type owl:Class ;
                                     rdfs:subClassOf cceo:MultimediaSoftwareApplication ;
                                     rdfs:label "Audio Editing Software Application"@en ;
                                     skos:definition "A Multimedia Software Application that is designed to enable a user to create and edit audio files."@en ;
                                     cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/Authentication
cceo:Authentication rdf:type owl:Class ;
                    rdfs:subClassOf cceo:ComputerProgramExecution ;
                    rdfs:label "Authentication"@en ;
                    skos:definition "A Computer Program Execution in which the identity of a user is verified."@en ;
                    cco2:ont00001754 "https://en.wikipedia.org/wiki/Authentication"^^xsd:anyURI ;
                    cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/Authorization
cceo:Authorization rdf:type owl:Class ;
                   rdfs:subClassOf cceo:ComputerProgramExecution ;
                   rdfs:label "Authorization"@en ;
                   skos:altLabel "Access Control"@en ;
                   skos:definition "A Computer Program Execution that bestows a user account with File Permissions."@en ;
                   cco2:ont00001754 "https://www.okta.com/identity-101/authentication-vs-authorization/"^^xsd:anyURI ;
                   cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/AutomatedTellerMachine
cceo:AutomatedTellerMachine rdf:type owl:Class ;
                            rdfs:subClassOf cco2:ont00000690 ;
                            rdfs:label "Automated Teller Machine"@en ;
                            skos:altLabel "ATM"@en ;
                            skos:definition "A Telecommunication Instrument which is designed to enable the customers of a financial institution to perform financial transactions, particularly cash withdrawal, without the need for a human cashier, clerk, or bank teller."@en ;
                            cco2:ont00001754 "https://en.wikipedia.org/wiki/Automated_teller_machine"^^xsd:anyURI ;
                            cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/AutonomousSystemNumberAddress
cceo:AutonomousSystemNumberAddress rdf:type owl:Class ;
                                   rdfs:subClassOf cco2:ont00000077 ;
                                   rdfs:label "Autonomous System Address"@en ;
                                   skos:altLabel "ASN Address"@en ;
                                   skos:definition "A Code Identifier that designates some Computer Autonomous System."@en ;
                                   cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/BackdoorProgram
cceo:BackdoorProgram rdf:type owl:Class ;
                     rdfs:subClassOf cceo:Malware ;
                     rdfs:label "Backdoor Program"@en ;
                     skos:definition "Malware that is designed to bypass normal authentication or encryption in a computer system in order to secure remote access to that system."@en ;
                     cco2:ont00001754 "https://en.wikipedia.org/wiki/Backdoor_(computing)"^^xsd:anyURI ;
                     cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/BackupFile
cceo:BackupFile rdf:type owl:Class ;
                rdfs:subClassOf cceo:DigitalFile ;
                rdfs:label "Backup File"@en ;
                skos:definition "A Digital File that that is designed to preserve the content of the original digital file in the case of destruction of the original."@en ;
                cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/BackupSoftware
cceo:BackupSoftware rdf:type owl:Class ;
                    rdfs:subClassOf cceo:UtilityProgram ;
                    rdfs:label "Backup Software"@en ;
                    skos:definition "A Utility Program that is designed to supplementary, exact copies of Digital Files, Databases, or of all the data on a Computer, which can be accessed later to restore the original contents in the event of data loss."@en ;
                    cco2:ont00001754 "https://en.wikipedia.org/wiki/Backup_software"^^xsd:anyURI ;
                    cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


