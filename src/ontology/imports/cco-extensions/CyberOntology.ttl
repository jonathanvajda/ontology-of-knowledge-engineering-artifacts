                             cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NetworkConnectionEstablished
cceo:NetworkConnectionEstablished rdf:type owl:Class ;
                                  rdfs:subClassOf cco2:ont00000847 ;
                                  rdfs:label "Network Connection Established"@en ;
                                  skos:definition "An Active Stasis in which multiple resources connected over a network are connected via their designed communication functions."@en ;
                                  cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NetworkConnectionExecution
cceo:NetworkConnectionExecution rdf:type owl:Class ;
                                rdfs:subClassOf cceo:ComputerProgramExecution ;
                                rdfs:label "Network Connection Execution"@en ;
                                skos:definition "A Computer Program Execution in which two resources are connected or unconnected on a network."@en ;
                                cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NetworkConnectionInitiated
cceo:NetworkConnectionInitiated rdf:type owl:Class ;
                                rdfs:subClassOf cceo:NetworkConnectionExecution ;
                                rdfs:label "Network Connection Initiation"@en ;
                                skos:definition "A Computer Program Execution in which two previously unconnected resources become connected on a network."@en ;
                                skos:scopeNote "For the state of two resources being connected see Network Connection Established."@en ;
                                cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NetworkConnectionTermination
cceo:NetworkConnectionTermination rdf:type owl:Class ;
                                  rdfs:subClassOf cceo:NetworkConnectionExecution ;
                                  rdfs:label "Network Connection Termination"@en ;
                                  skos:definition "A Computer Program Execution in which two previously connected resources on a network become unconnected."@en ;
                                  cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NetworkHost
cceo:NetworkHost rdf:type owl:Class ;
                 rdfs:subClassOf cco2:ont00000117 ;
                 rdfs:label "Network Host"@en ;
                 skos:definition "An Information Processing Artifact that is part of a Computer Network."@en ;
                 cco2:ont00001754 "https://en.wikipedia.org/wiki/Host_(network)"^^xsd:anyURI ;
                 cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NetworkHub
cceo:NetworkHub rdf:type owl:Class ;
                rdfs:subClassOf cceo:ComputerNetworkingDevice ;
                rdfs:label "Network Hub"@en ;
                skos:definition "A Computer Networking Device that connects multiple Ethernet devices together and making them act as a single network segment."@en ;
                cco2:ont00001754 "https://en.wikipedia.org/wiki/Ethernet_hub"^^xsd:anyURI ;
                cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NetworkIntrusionDetectionApplication
cceo:NetworkIntrusionDetectionApplication rdf:type owl:Class ;
                                          rdfs:subClassOf cceo:NetworkSecurityApplication ;
                                          rdfs:label "Network Intrusion Detection Application"@en ;
                                          skos:definition "A Network Security Application that is designed to detect and alert users or administrators about successful or failed attempts from unauthorized agents to gain access to some Computer Network."@en ;
                                          cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NetworkPacket
cceo:NetworkPacket rdf:type owl:Class ;
                   rdfs:subClassOf cco2:ont00000798 ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty obo:BFO_0000178 ;
                                     owl:someValuesFrom cceo:PacketHeader
                                   ] ;
                   rdfs:label "Network Packet"@en ;
                   skos:definition "An Information Bearing Artifact that bears some collection of data that is meant to be communicated over some Computer Network."@en ;
                   cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NetworkRouter
cceo:NetworkRouter rdf:type owl:Class ;
                   rdfs:subClassOf cceo:ComputerNetworkingDevice ;
                   rdfs:label "Network Router"@en ;
                   skos:altLabel "Router"@en ;
                   skos:definition "A Computer Networking Device that connects multiple Computer Networks by forwarding data packets between them."@en ;
                   cco2:ont00001754 "https://en.wikipedia.org/wiki/Router_(computing)"^^xsd:anyURI ;
                   cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NetworkSecurityApplication
cceo:NetworkSecurityApplication rdf:type owl:Class ;
                                rdfs:subClassOf cceo:UtilityProgram ;
                                rdfs:label "Network Security Application"@en ;
                                skos:definition "A Utility Program that is designed to protect the usability and integrity of some Computer Network and its data."@en ;
                                cco2:ont00001754 "http://www.cisco.com/c/en/us/products/security/what-is-network-security.html"^^xsd:anyURI ;
                                cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NetworkServer
cceo:NetworkServer rdf:type owl:Class ;
                   rdfs:subClassOf cceo:ComputerProgram ;
                   rdfs:label "Network Server"@en ;
                   skos:altLabel "Server"@en ;
                   skos:definition "A Computer Program that enables clients to access a Computer Service Function over a Computer Network."@en ;
                   cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NetworkServiceFunction
cceo:NetworkServiceFunction rdf:type owl:Class ;
                            rdfs:subClassOf cceo:InformationProcessingArtifactFunction ;
                            rdfs:label "Network Service Function"@en ;
                            skos:altLabel "Network Service"@en ;
                            skos:definition "An Information Processing Artifact Function that when realized is in a process of a client accessing some other Information Processing Artifact Function, called a service, over a Computer Network."@en ;
                            skos:scopeNote "'Service' typically refers to the functionality of some program, or other resource, e.g., file management. The ability for a server to provide that functionality requires the existence of an additional function, which is what these classes are designed to represent. However, the service-enabling function is different from the service itself. Since many types of programs and other information processing artifacts can be offered as services, it doesn’t make sense to create duplicate terms for when an application is a service vs. when it isn’t. By analogy, consider a pizza restaurant that offers dine-in, take-out, and delivery options. These three modes of getting your pizza don’t make for three different kinds of pizza. Same pizza, same restaurant, different ways of accessing."@en ;
                            cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NetworkSwitch
cceo:NetworkSwitch rdf:type owl:Class ;
                   rdfs:subClassOf cceo:ComputerNetworkingDevice ;
                   rdfs:label "Network Switch"@en ;
                   skos:altLabel "Switch"@en ;
                   skos:definition "A Computer Networking Device that connects devices together on a single Computer Network by using packet switching to receive, process, and forward data to the destination device."@en ;
                   cco2:ont00001754 "https://en.wikipedia.org/wiki/Network_switch"^^xsd:anyURI ;
                   cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NetworkUtility
cceo:NetworkUtility rdf:type owl:Class ;
                    rdfs:subClassOf cceo:UtilityProgram ;
                    rdfs:label "Network Utility"@en ;
                    skos:definition "A Utility Program that is designed to analyze and configure various aspects of a Computer Network."@en ;
                    cco2:ont00001754 "https://en.wikipedia.org/wiki/Network_utility"^^xsd:anyURI ;
                    cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


