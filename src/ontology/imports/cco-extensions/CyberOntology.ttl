                    rdfs:label "Overlay Network"@en ;
                    skos:definition "A Computer Network that is built on top of another Computer Network."@en ;
                    cco2:ont00001754 "https://en.wikipedia.org/wiki/Overlay_network"^^xsd:anyURI ;
