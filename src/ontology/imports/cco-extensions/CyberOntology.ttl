                          rdfs:subClassOf cceo:NetworkConnectionInitiated ;
                          rdfs:label "TCP Three-Way Handshake"@en ;
                          skos:definition "A Network Connection Initiation in which two hosts establish a network connection by means of Transmission Control Protocol flags (in order): SYN, SYN-ACK, and ACK."@en ;
                          cco2:ont00001754 "https://en.wikipedia.org/wiki/Transmission_Control_Protocol#Connection_establishment"^^xsd:anyURI ;
                          cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


