             rdfs:label "Rootkit"@en ;
             skos:definition "Malware that is designed to enable an unauthorized user to gain administrator access to a Computer."@en ;
             cco2:ont00001754 "https://en.wikipedia.org/wiki/Rootkit"^^xsd:anyURI ;
             cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


