###  http://www.ontologyrepository.com/CommonCoreOntologies/WirelessNetworkAccessPoint
cceo:WirelessNetworkAccessPoint rdf:type owl:Class ;
                                owl:equivalentClass [ owl:intersectionOf ( cco2:ont00000346
                                                                           [ rdf:type owl:Restriction ;
                                                                             owl:onProperty obo:BFO_0000196 ;
                                                                             owl:someValuesFrom cceo:WirelessNetworkAccessFunction
                                                                           ]
                                                                         ) ;
                                                      rdf:type owl:Class
                                                    ] ;
                                rdfs:subClassOf cco2:ont00000346 ;
                                rdfs:label "Network Access Point"@en ;
                                skos:altLabel "AP"@en ,
                                              "Access Point"@en ,
                                              "Wireless Access Point"@en ,
                                              "Wireless Network Access Point"@en ;
                                skos:definition "A Communication Instrument that is designed to allow devices to wirelessly connect to the same Computer Network."@en ;
                                cco2:ont00001754 "IEEE 802.11, Local Area Network standards. Available at: https://standards.ieee.org/ieee/802.11/7028/"@en ;
                                cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


