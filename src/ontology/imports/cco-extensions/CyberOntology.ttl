###  http://www.ontologyrepository.com/CommonCoreOntologies/SYNFlood
cceo:SYNFlood rdf:type owl:Class ;
              rdfs:subClassOf cceo:DenialOfService ;
              rdfs:label "SYN Flood"@en ;
              skos:definition "A Denial of Service in which an Agent sends a succession of SYN requests to a target's system in an attempt to consume enough server resources to make the system unresponsive to legitimate traffic."@en ;
              cco2:ont00001754 "https://en.wikipedia.org/wiki/SYN_flood"^^xsd:anyURI ;
              cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


