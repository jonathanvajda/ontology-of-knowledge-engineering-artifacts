cceo:BroadbandCommunicationArtifactFunction rdf:type owl:Class ;
                                            rdfs:subClassOf cco2:ont00000727 ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty obo:BFO_0000197 ;
                                                              owl:someValuesFrom cco2:ont00000998
                                                            ] ;
                                            rdfs:label "Broadband Communication Artifact Function"@en ;
