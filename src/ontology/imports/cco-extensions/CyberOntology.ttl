###  http://www.ontologyrepository.com/CommonCoreOntologies/MemoryCorruption
cceo:MemoryCorruption rdf:type owl:Class ;
                      rdfs:subClassOf cceo:CyberVulnerability ;
                      rdfs:label "Memory Corruption"@en ;
                      skos:definition "A Cyber Vulnerability that is realized by a Cyber Attack which writes to memory outside the bounds of a buffer, when the root cause is something other than a sequential copies of excessive data from a fixed starting location."@en ;
                      skos:scopeNote "This may include issues such as incorrect pointer arithmetic, accessing invalid pointers due to incomplete initialization or memory release, etc."@en ;
                      cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


