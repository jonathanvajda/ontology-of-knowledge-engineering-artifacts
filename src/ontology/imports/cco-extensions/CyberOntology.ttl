###  http://www.ontologyrepository.com/CommonCoreOntologies/WirelessNetworkAccessFunction
cceo:WirelessNetworkAccessFunction rdf:type owl:Class ;
                                   rdfs:subClassOf cceo:InformationProcessingArtifactFunction ;
                                   rdfs:label "Wireless Network Access Function"@en ;
                                   skos:altLabel "AP Function"@en ,
                                                 "Access Point Function"@en ,
                                                 "Wireless Access Point Function"@en ,
                                                 "Wireless Network Access Point Function"@en ;
                                   skos:definition "An Information Processing Artifact function that is realized in processes where Computing Devices are able to wirelessly connect to the same Computer Network."@en ;
                                   cco2:ont00001754 "IEEE 802.11, Local Area Network standards. Available at: https://standards.ieee.org/ieee/802.11/7028/"@en ;
