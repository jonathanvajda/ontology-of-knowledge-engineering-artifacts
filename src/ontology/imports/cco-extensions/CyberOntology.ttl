                                cco2:ont00001754 "http://www.cisco.com/c/en/us/products/security/firewalls/what-is-a-firewall.html"^^xsd:anyURI ;
                                cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


