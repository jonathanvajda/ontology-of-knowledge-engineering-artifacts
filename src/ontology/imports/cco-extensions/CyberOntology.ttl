               skos:definition "An Information Bearing Artifact that is an ordered sequence of Nodes."@en ;
               cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NodeTree
cceo:NodeTree rdf:type owl:Class ;
              rdfs:subClassOf cco2:ont00000798 ;
              rdfs:label "Node Tree"@en ;
              skos:definition "An Information Bearing Entity that consists of a hierarchy of Nodes with exactly one root Node."@en ;
              cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/NoteManagementSoftwareApplication
cceo:NoteManagementSoftwareApplication rdf:type owl:Class ;
                                       rdfs:subClassOf cceo:InformationWorkerSoftware ;
                                       rdfs:label "Note Management Software Application"@en ;
                                       skos:definition "An Information Worker Software Application that is designed to enable a user to record information captured from another source."@en ;
                                       cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/Ontology
cceo:Ontology rdf:type owl:Class ;
              rdfs:subClassOf cco2:ont00000798 ;
              rdfs:label "Ontology"@en ;
              skos:definition "An Information Bearing Artifact that is designed to represent types of entities and the relationships between them, and which can be encoded in a Computer Language."@en ;
              cco2:ont00001754 "R. Arp, B. Smith, and A.D. Spear, \"Building Ontologies with Basic Formal Ontology,\" Cambridge, MA: MIT Press, 2015"@en ;
              cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


