                                        rdfs:label "Ontology Editing Software Application"@en ;
                                        skos:definition "An Information Worker Software Application that is designed to enable a user to create and manage an Ontology."@en ;
                                        cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/OpenSystemsInterconnectionCategory
cceo:OpenSystemsInterconnectionCategory rdf:type owl:Class ;
                                        rdfs:subClassOf cco2:ont00000293 ;
                                        rdfs:label "Open Systems Interconnection Category"@en ;
                                        skos:altLabel "OSI Category"@en ;
                                        skos:definition "A Nominal Measurement Information Content Entity that categorizes pieces of hardware or software based on their communication functionality."@en ;
                                        cco2:ont00001754 "https://en.wikipedia.org/wiki/OSI_model"^^xsd:anyURI ;
                                        cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/OperatingSystem
cceo:OperatingSystem rdf:type owl:Class ;
                     rdfs:subClassOf cceo:SystemSoftware ;
                     rdfs:label "Operating System"@en ;
                     skos:altLabel "OS"@en ;
                     skos:definition "System Software that is designed to manage Computer hardware and software resources and provides common services for Computer Programs."@en ;
                     skos:scopeNote "With the exception of firmware, all computer programs require an operating system to function."@en ;
                     cco2:ont00001754 "https://en.wikipedia.org/wiki/Operating_system"^^xsd:anyURI ;
                     cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/OperatingSystemSoftwareModel
cceo:OperatingSystemSoftwareModel rdf:type owl:Class ;
                                  rdfs:subClassOf cceo:ComputerProgramArtifactModel ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty cco2:ont00001942 ;
                                                    owl:someValuesFrom cceo:OperatingSystem
                                                  ] ;
                                  rdfs:label "Operating System Software"@en ;
                                  skos:definition "A Computer Program Content that prescribes some Operating System."@en ;
                                  skos:scopeNote "Subclasses of Operating System Model are fiat collections that group families of related models based on the developer or a shared evolutionary history. It is reasonable to assume these classes are best considered as enumerations of all the known models that belong in that family or developmental history."@en ;
                                  cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/OrderedPair
cceo:OrderedPair rdf:type owl:Class ;
                 rdfs:subClassOf cceo:Tuple ;
                 rdfs:label "Ordered Pair"@en ;
                 skos:definition "A Tuple which consists of exactly two ordered elements."@en ;
                 cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


###  http://www.ontologyrepository.com/CommonCoreOntologies/OrphanComputerProgramExecution
cceo:OrphanComputerProgramExecution rdf:type owl:Class ;
                                    rdfs:subClassOf cceo:ChildComputerProgramExecution ;
                                    rdfs:comment "TO DO: Shall be axiomatized as an equivalency, e.g., Child Program Execution and process started by some (Computer Program Execution and participates in some Terminated Stasis)."@en ;
                                    rdfs:label "Orphan Computer Program Execution"@en ;
                                    skos:altLabel "Orphan Computer Process"@en ;
                                    skos:definition "A Child Computer Program Execution whose Parent Computer Process has terminated."@en ;
                                    cco2:ont00001754 "https://en.wikipedia.org/wiki/Orphan_process"^^xsd:anyURI ;
                                    cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


