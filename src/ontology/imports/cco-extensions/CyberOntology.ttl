                                                owl:onProperty cco2:ont00001920 ;
                                                owl:someValuesFrom cco2:ont00000653
                                              ] ;
                              rdfs:label "Computer Program Execution"@en ;
                              skos:altLabel "Computer Process"@en ;
                              skos:definition "A Mechanical Process that is comprised of a sequence of simple operations performed by a Central Processing Unit or some Computer Program according to the instructions of some Algorithm."@en ;
                              cco2:ont00001760 "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"^^xsd:anyURI .


