@prefix : <https://github.com/jonathanvajda/okea/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix cceo: <http://www.ontologyrepository.com/CommonCoreOntologies/> .
@prefix cco2: <https://www.commoncoreontologies.org/> .
@prefix okea: <https://github.com/jonathanvajda/okea/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oboInOwl: <http://www.geneontology.org/formats/oboInOwl#> .

###  http://purl.obolibrary.org/obo/IAO_0000114
obo:IAO_0000114 rdf:type owl:AnnotationProperty .


###  http://purl.obolibrary.org/obo/IAO_0000300
obo:IAO_0000300 rdf:type owl:Class ;
                rdfs:subClassOf cco2:ont00000958 ;
                obo:IAO_0000114 "http://purl.obolibrary.org/obo/IAO_0000123" ;
                rdfs:label "textual entity"@en ;
                skos:definition "A textual entity is a part of a manifestation (FRBR sense), a generically dependent continuant whose concretizations are patterns of glyphs intended to be interpreted as words, formulas, etc."@en ;
                cco2:ont00001760 obo:iao.owl .


###  http://purl.obolibrary.org/obo/IAO_0000642
obo:IAO_0000642 rdf:type owl:Class ;
                rdfs:subClassOf obo:IAO_0000300 ;
                rdfs:label "requirements textual entity"@en ;
                skos:definition "A textual entity that expresses the requirements necessary to use a resource, e.g. software."@en ;
                cco2:ont00001760 obo:iao.owl .

                
###  http://purl.obolibrary.org/obo/IAO_8000000
obo:IAO_8000000 rdf:type owl:Class ;
                rdfs:subClassOf cco2:ont00000958 ;
                rdfs:label "ontology module"@en ;
                skos:altLabel "ontology file"@en ;
                skos:definition "A representational artifact that consists of a set of definitions of classes (types) and relations that describe a specific domain of reality"@en ;
                cco2:ont00001760 obo:iao.owl .


###  http://purl.obolibrary.org/obo/IAO_8000002
obo:IAO_8000002 rdf:type owl:Class ;
                rdfs:subClassOf obo:IAO_8000000 ;
                rdfs:label "editors ontology module"@en ;
                skos:altLabel "source ontology module"@en ;
                skos:definition "An ontology module that is intended to be directly edited, typically managed in source control, and typically not intended for direct consumption by end-users."@en ;
                cco2:ont00001760 obo:iao.owl .


###  http://purl.obolibrary.org/obo/IAO_8000003
obo:IAO_8000003 rdf:type owl:Class ;
                rdfs:subClassOf obo:IAO_8000000 ;
                rdfs:label "main release ontology module"@en ;
                skos:definition "An ontology module that is intended to be the primary release product and the one consumed by the majority of tools."@en ;
                cco2:ont00001760 obo:iao.owl .


###  http://purl.obolibrary.org/obo/OBI_0001755
obo:OBI_0001755 rdf:type owl:Class ;
                rdfs:subClassOf cco2:ont00000965 ;
                obo:IAO_0000114 obo:IAO_0000122 ;
                rdfs:label "selection criterion"@en ;
                skos:definition "A directive information entity which defines and states a principle of standard by which selection process may take place."@en ;
                cco2:ont00001760 obo:obi.owl .


###  http://purl.obolibrary.org/obo/OBI_0500026
obo:OBI_0500026 rdf:type owl:Class ;
                rdfs:subClassOf obo:OBI_0001755 ;
                obo:IAO_0000114 obo:IAO_0000122 ;
                rdfs:label "eligibility criterion"@en ;
                skos:definition "An eligibility criterion (rule) is_a selection criterion which defines and states the requirements (positive or negative) for an entity to be considered as suitable for a given task or participation in a process."@en ;
                cco2:ont00001760 obo:obi.owl .


###  http://semanticscience.org/resource/SIO_000331
<http://semanticscience.org/resource/SIO_000331> rdf:type owl:Class ;
                                                 rdfs:subClassOf obo:IAO_8000000 ;
                                                 rdfs:label "Web Ontology Language ontology"@en ;
                                                 skos:altLabel "OWL ontology"@en ;
                                                 skos:definition "An OWL ontology is an ontology as specified by the W3C OWL specification."@en ;
                                                 cco2:ont00001760 <http://semanticscience.org/ontology/sio.owl> .


###  http://semanticscience.org/resource/SIO_000622
<http://semanticscience.org/resource/SIO_000622> rdf:type owl:Class ;
                                                 rdfs:subClassOf obo:IAO_8000000 ;
                                                 rdfs:label "Resource Description Framework Schema ontology"@en ;
                                                 skos:altLabel "RDFS ontology"@en ;
                                                 skos:definition "An RDFS ontology is an ontology that conforms to the syntax and semantics of the Resource Description Framework Schema (RDFS)."@en ;
                                                 cco2:ont00001760 <http://semanticscience.org/ontology/sio.owl> .


###  http://semanticscience.org/resource/SIO_000623
<http://semanticscience.org/resource/SIO_000623> rdf:type owl:Class ;
                                                 rdfs:subClassOf obo:IAO_8000000 ;
                                                 rdfs:label "Open Biological and Biomedical Ontology"@en ;
                                                 skos:altLabel "OBO ontology"@en ;
                                                 skos:definition "An OBO ontology is an ontology document as specified by the Open Biological Ontology community."@en ;
                                                 cco2:ont00001760 <http://semanticscience.org/ontology/sio.owl> .