@prefix : <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix cceo: <http://www.ontologyrepository.com/CommonCoreOntologies/> .
@prefix cco2: <https://www.commoncoreontologies.org/> .
@prefix okea: <https://github.com/jonathanvajda/okea/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oboInOwl: <http://www.geneontology.org/formats/oboInOwl#> .
@base <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .

<https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> rdf:type owl:Ontology ;
                                                                                 owl:versionIRI <https://github.com/jonathanvajda/okea/2026-03-18/OntologyOfKnowledgeEngineeringArtifacts> ;
                                                                                 dcterms:creator "Jonathan Vajda"@en ;
                                                                                 dcterms:description "The Ontology of Knowledge Engineering Artifacts is a reference ontology that extends the Information Entity Ontology (in CCO) to represent various information artifacts that surround the use of linked data and ontologies."@en ;
                                                                                 rdfs:label "Ontology of Knowledge Engineering Artifacts"@en ;
                                                                                 owl:versionInfo "2026-03-18"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.obolibrary.org/obo/IAO_0000114
obo:IAO_0000114 rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/bibliographicCitation
dcterms:bibliographicCitation rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/identifier
dcterms:identifier rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#scopeNote
skos:scopeNote rdf:type owl:AnnotationProperty .


###  https://github.com/jonathanvajda/okea/has_data_description_text_value
okea:has_data_description_text_value rdf:type owl:AnnotationProperty ;
                                     rdfs:label "has data description"@en ;
                                     cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> ;
                                     rdfs:subPropertyOf dcterms:description ;
                                     rdfs:range xsd:string .


###  https://github.com/jonathanvajda/okea/has_standardized_datafield_identifier
okea:has_standardized_datafield_identifier rdf:type owl:AnnotationProperty ;
                                           rdfs:label "has standardized datafield identifier"@en ;
                                           skos:definition "An identifier of a datafield, whose code identifier is standardized or normalizedprocedurally or according to some schema."@en ;
                                           skos:example "NIEM  uses an ID with a namespace prefix and then a human-readable identifier. E.g., 'nc:OrganizationType' to identify the data type that is about a 'body of people organize for a particular purpose.'"@en ;
                                           skos:scopeNote "As a matter of data architecture, data for entities are given unique identifiers that can be used univocally or analogously in different data tables or databases. The tokenenization of the identifier is what is in view."@en ;
                                           cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> ;
                                           rdfs:subPropertyOf dcterms:identifier ;
                                           rdfs:range xsd:string .


###  https://github.com/jonathanvajda/okea/representation_conforms_to_specification
okea:representation_conforms_to_specification rdf:type owl:AnnotationProperty ;
                                              rdfs:label "representation conforms to specification"@en ;
                                              skos:definition "x representation conforms to specification y iff x is a representation, y is a specification (directive information content entity), and y specifies x, and x exemplifies the specification y."@en ;
                                              cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://www.commoncoreontologies.org/ont00001753
cco2:ont00001753 rdf:type owl:AnnotationProperty .


###  https://www.commoncoreontologies.org/ont00001760
cco2:ont00001760 rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://github.com/jonathanvajda/okea/ont000010
okea:ont000010 rdf:type owl:ObjectProperty ;
               owl:inverseOf okea:ont000011 ;
               rdfs:domain okea:ont000002 ;
               rdfs:range cco2:ont00000958 ;
               rdfs:label "has competency question"@en ;
               skos:definition "x has competency question y iff x is some information content entity, y is a competency question, and y is intended to be used to evaluate coverage of entities (or relations) for some portion of reality that x represents."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000011
okea:ont000011 rdf:type owl:ObjectProperty ;
               rdfs:domain cco2:ont00000958 ;
               rdfs:range okea:ont000002 ;
               rdfs:label "is competency question of"@en ;
               skos:definition "x is competency question of y iff y is some information content entity, x is a competency question, and x is intended to be used to evaluate coverage of entities (or relations) for some portion of reality that y represents."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000012
okea:ont000012 rdf:type owl:ObjectProperty ;
               owl:inverseOf okea:ont000013 ;
               rdfs:domain cco2:ont00000958 ;
               rdfs:range okea:ont000004 ;
               rdfs:label "has mermaid diagram"@en ;
               skos:definition "x has mermaid diagram y iff x is some information content entity, y is a mermaid diagram (content entity), and y is intended to be used to represent visually some entity (or relations) for some portion of reality that x represents."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000013
okea:ont000013 rdf:type owl:ObjectProperty ;
               rdfs:domain okea:ont000004 ;
               rdfs:range cco2:ont00000958 ;
               rdfs:label "is mermaid diagram of"@en ;
               skos:definition "x is mermaid diagram of y iff y is some information content entity, x is a mermaid diagram (content entity), and x is intended to be used to represent visually some entity (or relations) for some portion of reality that y represents."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000014
okea:ont000014 rdf:type owl:ObjectProperty ;
               rdfs:label "has formalization"@en ;
               skos:definition "x has competency question y iff x" ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000015
okea:ont000015 rdf:type owl:ObjectProperty ;
               rdfs:label "is formalization of"@en ;
               skos:definition "x is competency question of y iff x..." ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000026
okea:ont000026 rdf:type owl:ObjectProperty ;
               rdfs:label "has selection criterion"@en ;
               skos:definition "x has selection criterion y iff x is a directive information content entity (i.e., a standard or principle), y is a selection criterion, y delineates some necessary or sufficient condition z, and x is about z."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000027
okea:ont000027 rdf:type owl:ObjectProperty ;
               rdfs:label "is selection criterion of"@en ;
               skos:definition "x is selection criteria of y iff y has selection criterion x."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


#################################################################
#    Data properties
#################################################################

###  https://github.com/jonathanvajda/okea/has_competency_question_text_value
okea:has_competency_question_text_value rdf:type owl:DatatypeProperty ;
                                        rdfs:subPropertyOf cco2:ont00001765 ;
                                        rdfs:range xsd:string ;
                                        rdfs:label "has competency question text value"@en ;
                                        cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/has_git_respository_url
okea:has_git_respository_url rdf:type owl:DatatypeProperty ;
                             rdfs:range xsd:anyURI ;
                             rdfs:label "has git respository url"@en ;
                             skos:definition "x has git repository url y iff x is some entity and y is the uniform resource locator (URL) designating where code is under git versioning."@en ;
                             cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/has_mermaid_diagram_text_value
okea:has_mermaid_diagram_text_value rdf:type owl:DatatypeProperty ;
                                    rdfs:subPropertyOf cco2:ont00001765 ;
                                    rdfs:range xsd:string ;
                                    rdfs:label "has mermaid diagram text value"@en ;
                                    cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/has_query_text_value
okea:has_query_text_value rdf:type owl:DatatypeProperty ;
                          rdfs:subPropertyOf cco2:ont00001765 ;
                          rdfs:range xsd:string ;
                          rdfs:label "has query text value"@en ;
                          cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/has_sparql_query_text_value
okea:has_sparql_query_text_value rdf:type owl:DatatypeProperty ;
                                 rdfs:subPropertyOf okea:has_query_text_value ;
                                 rdfs:range xsd:string ;
                                 rdfs:label "has SPARQL query text value"@en ;
                                 cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/has_sparql_update_text_value
okea:has_sparql_update_text_value rdf:type owl:DatatypeProperty ;
                                  rdfs:subPropertyOf okea:has_sparql_query_text_value ,
                                                     okea:has_update_query_text_value ;
                                  rdfs:range xsd:string ;
                                  rdfs:label "has SPARQL update query text value"@en ;
                                  cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/has_sql_query_text_value
okea:has_sql_query_text_value rdf:type owl:DatatypeProperty ;
                              rdfs:subPropertyOf okea:has_query_text_value ;
                              rdfs:range xsd:string ;
                              rdfs:label "has SQL query text value"@en ;
                              cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/has_sql_update_text_value
okea:has_sql_update_text_value rdf:type owl:DatatypeProperty ;
                               rdfs:subPropertyOf okea:has_sql_query_text_value ,
                                                  okea:has_update_query_text_value ;
                               rdfs:range xsd:string ;
                               rdfs:label "has SQL update query text value"@en ;
                               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/has_update_query_text_value
okea:has_update_query_text_value rdf:type owl:DatatypeProperty ;
                                 rdfs:subPropertyOf okea:has_query_text_value ;
                                 rdfs:range xsd:string ;
                                 rdfs:label "has update query text value"@en ;
                                 cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://www.commoncoreontologies.org/ont00001765
cco2:ont00001765 rdf:type owl:DatatypeProperty .


#################################################################
#    Classes
#################################################################

###  http://purl.obolibrary.org/obo/IAO_0000300
obo:IAO_0000300 rdf:type owl:Class ;
                rdfs:subClassOf cco2:ont00000958 ;
                obo:IAO_0000114 "http://purl.obolibrary.org/obo/IAO_0000123" ;
                rdfs:label "textual entity"@en ;
                skos:definition "A textual entity is a part of a manifestation (FRBR sense), a generically dependent continuant whose concretizations are patterns of glyphs intended to be interpreted as words, formulas, etc."@en ;
                cco2:ont00001760 obo:iao.owl .


###  http://purl.obolibrary.org/obo/IAO_0000642
obo:IAO_0000642 rdf:type owl:Class ;
                rdfs:subClassOf obo:IAO_0000300 ;
                rdfs:label "requirements textual entity"@en ;
                skos:definition "A textual entity that expresses the requirements necessary to use a resource, e.g. software."@en ;
                cco2:ont00001760 obo:iao.owl .


###  http://purl.obolibrary.org/obo/IAO_8000000
obo:IAO_8000000 rdf:type owl:Class ;
                rdfs:subClassOf cco2:ont00000958 ;
                rdfs:label "ontology module"@en ;
                skos:altLabel "ontology file"@en ;
                skos:definition "A representational artifact that consists of a set of definitions of classes (types) and relations that describe a specific domain of reality"@en ;
                cco2:ont00001760 obo:iao.owl .


###  http://purl.obolibrary.org/obo/IAO_8000002
obo:IAO_8000002 rdf:type owl:Class ;
                rdfs:subClassOf obo:IAO_8000000 ;
                rdfs:label "editors ontology module"@en ;
                skos:altLabel "source ontology module"@en ;
                skos:definition "An ontology module that is intended to be directly edited, typically managed in source control, and typically not intended for direct consumption by end-users."@en ;
                cco2:ont00001760 obo:iao.owl .


###  http://purl.obolibrary.org/obo/IAO_8000003
obo:IAO_8000003 rdf:type owl:Class ;
                rdfs:subClassOf obo:IAO_8000000 ;
                rdfs:label "main release ontology module"@en ;
                skos:definition "An ontology module that is intended to be the primary release product and the one consumed by the majority of tools."@en ;
                cco2:ont00001760 obo:iao.owl .


###  http://purl.obolibrary.org/obo/OBI_0001755
obo:OBI_0001755 rdf:type owl:Class ;
                rdfs:subClassOf cco2:ont00000965 ;
                obo:IAO_0000114 obo:IAO_0000122 ;
                rdfs:label "selection criterion"@en ;
                skos:definition "A directive information entity which defines and states a principle of standard by which selection process may take place."@en ;
                cco2:ont00001760 obo:obi.owl .


###  http://purl.obolibrary.org/obo/OBI_0500026
obo:OBI_0500026 rdf:type owl:Class ;
                rdfs:subClassOf obo:OBI_0001755 ;
                obo:IAO_0000114 obo:IAO_0000122 ;
                rdfs:label "eligibility criterion"@en ;
                skos:definition "An eligibility criterion (rule) is_a selection criterion which defines and states the requirements (positive or negative) for an entity to be considered as suitable for a given task or participation in a process."@en ;
                cco2:ont00001760 obo:obi.owl .


###  http://semanticscience.org/resource/SIO_000331
<http://semanticscience.org/resource/SIO_000331> rdf:type owl:Class ;
                                                 rdfs:subClassOf obo:IAO_8000000 ;
                                                 rdfs:label "OWL ontology"@en ;
                                                 skos:definition "An OWL ontology is an ontology as specified by the W3C OWL specification."@en ;
                                                 cco2:ont00001760 <http://semanticscience.org/ontology/sio.owl> .


###  http://semanticscience.org/resource/SIO_000622
<http://semanticscience.org/resource/SIO_000622> rdf:type owl:Class ;
                                                 rdfs:subClassOf obo:IAO_8000000 ;
                                                 rdfs:label "RDFS ontology"@en ;
                                                 skos:definition "An RDFS ontology is an ontology that conforms to the syntax and semantics of the Resource Description Framework Schema (RDFS)."@en ;
                                                 cco2:ont00001760 <http://semanticscience.org/ontology/sio.owl> .


###  http://semanticscience.org/resource/SIO_000623
<http://semanticscience.org/resource/SIO_000623> rdf:type owl:Class ;
                                                 rdfs:subClassOf obo:IAO_8000000 ;
                                                 rdfs:label "OBO ontology"@en ;
                                                 skos:definition "An OBO ontology is an ontology document as specified by the Open Biological Ontology community."@en ;
                                                 cco2:ont00001760 <http://semanticscience.org/ontology/sio.owl> .


###  http://www.ontologyrepository.com/CommonCoreOntologies/ActOfRequestingInformation
cceo:ActOfRequestingInformation rdf:type owl:Class .


###  https://github.com/jonathanvajda/okea/ont000001
okea:ont000001 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000958 ;
               dcterms:bibliographicCitation "Braun, D. (2022). Propositions and Questions. In Chris Tillman and Adam Murray (Eds), Routledge Handbook of Propositions."@en ,
                                             "https://doi.org/10.4324/9781315270500-34"^^xsd:anyURI ;
               rdfs:label "Interrogative Information Content Entity"@en ;
               skos:altLabel "Question"@en ;
               skos:definition "An Information Content Entity that is the object of some act of asking or wondering."@en ;
               skos:scopeNote "Strictly speaking, questions are the contents of interrogative sentences."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000002
okea:ont000002 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000001 ;
               dcterms:bibliographicCitation "Grüninger, M., Fox, M.S. (1995). The Role of Competency Questions in Enterprise Engineering. In: Rolstadås, A. (eds) Benchmarking — Theory and Practice. IFIP Advances in Information and Communication Technology. Springer, Boston, MA."@en ,
                                             "https://doi.org/10.1007/978-0-387-34847-6_3"^^xsd:anyURI ;
               rdfs:label "Competency Question Content Entity"@en ;
               skos:altLabel "CQ"@en ,
                             "Competency Question"@en ;
               skos:definition "An Interrogative Information Content Entity that is expressed in natural language, that is designed to assist in identifying what information is to be returned for some information system query (tell-and-ask service), with respect to whether a framework has coverage of the terms, relationships, and inferences to enable the query."@en ;
               skos:scopeNote "A competency question is typically used to provide a benchmark for what queries some information system is to handle and what vocabularies and taxonomies are relevant to answer the user's question."@en ;
               cco2:ont00001753 "CQ"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000003
okea:ont000003 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000001 ;
               dcterms:bibliographicCitation "The Department of Defense Architecture Framework (DoDAF), Version 2.0 (2009). Volume 1, 43-44."@en ,
                                             "https://dodcio.defense.gov/Portals/0/Documents/DODAF/DoDAF%20V2%20-%20Volume%201.pdf"^^xsd:anyURI ;
               rdfs:label "Decision Support Question Content Entity"@en ;
               skos:altLabel "DSQ"@en ,
                             "Decision Support Question"@en ;
               skos:definition "An Interrogative Information Content Entity that is expressed in natural language, that is designed to assist in identifying critical information requirements (CIRs) for making decisions regarding mission essential tasks (METs)."@en ;
               skos:scopeNote "A decision support question may involve one or many competency questions, which, when considered as a collection, are relevant for enabling a decision-maker to perform their METs."@en ;
               cco2:ont00001753 "DSQ"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000004
okea:ont000004 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000958 ;
               dcterms:bibliographicCitation "https://en.wikipedia.org/w/index.php?title=Mermaid&oldid=1341883926"^^xsd:anyURI ;
               rdfs:label "Mermaid Diagram"@en ;
               skos:definition "An Information Content Entity that represents some portion of reality visually, whose syntactic rules for generating an image is prescribed by the Mermaid syntax specification."@en ;
               skos:example "Mermaid syntax: ```graph TD; A[Agent<br>Activity ID: 123.12.001<br>System] --input in--> B{Is the system available:<br>Yes or No?}```"@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000005
okea:ont000005 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000016 ;
               rdfs:label "SQL Query"@en ;
               skos:definition "A Database Query that is expressed in the syntax prescribed by the Structured Query Language specifications."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000006
okea:ont000006 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000005 ;
               rdfs:label "SQL Update Query"@en ;
               skos:definition "A SQL Query that is designed to request a change in data assertions stored by an information system."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000007
okea:ont000007 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000016 ;
               rdfs:label "SPARQL Query"@en ;
               skos:definition "A Database Query that is expressed in the syntax prescribed by the SPARQL Protocol and RDF Query Language specifications."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000008
okea:ont000008 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000007 ;
               rdfs:label "SPARQL Update Query"@en ;
               skos:definition "A SPARQL query is designed to request a change in data assertions stored by an information system."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000009
okea:ont000009 rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:unionOf ( cco2:ont00000127
                                                   cco2:ont00000653
                                                 )
                                   ] ;
               rdfs:subClassOf cco2:ont00000965 ;
               rdfs:label "Business Rule"@en ;
               skos:altLabel "Decision Logic" ;
               skos:definition "A Directive Information Content Entity that is designed to direct planned processes performed by an organization and is either an Algorithm or a Performance Specification."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000016
okea:ont000016 rdf:type owl:Class ;
               rdfs:subClassOf okea:ont000001 ;
               rdfs:label "Database Query"@en ;
               skos:definition "An Interrogative Information Content Entity that is expressed in the syntax prescribed some query language specification."@en ;
               cco2:ont00001760 <https://github.com/jonathanvajda/okea/OntologyOfKnowledgeEngineeringArtifacts> .


###  https://github.com/jonathanvajda/okea/ont000018
okea:ont000018 rdf:type owl:Class ;
               rdfs:subClassOf cco2:ont00000398 ;
               rdfs:label "W3C standard"@en ;
               skos:definition "A Reference System that is about a set of technical standards for the World Wide Web (W3C)."@en ;
