###  https://github.com/jonathanvajda/SemanticArtifactOntology/has_competency_question_text_value
semarto:has_competency_question_text_value rdf:type owl:DatatypeProperty ;
                                           rdfs:subPropertyOf cco2:ont00001765 ;
                                           rdfs:range xsd:string ;
                                           rdfs:label "has competency question text value"@en ;
                                           cco2:ont00001760 <https://github.com/jonathanvajda/SemanticArtifactOntology> .


###  https://github.com/jonathanvajda/SemanticArtifactOntology/has_git_respository_url
semarto:has_git_respository_url rdf:type owl:DatatypeProperty ;
                                rdfs:range xsd:anyURI ;
                                rdfs:label "has git respository url"@en ;
                                skos:definition "x has git repository url y iff x is some entity and y is the uniform resource locator (URL) designating where code is under git versioning."@en ;
                                cco2:ont00001760 <https://github.com/jonathanvajda/SemanticArtifactOntology> .


